{
  "_version": "1.82.0",
  "sap.app": {
    "id": "zapp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.20.4",
      "toolsId": "c2dad03e-fdf3-4d1a-8b4f-439157dc7858"
    },
    "crossNavigation": {
      "inbounds": {
        "ZCustomMaster-maintain": {
          "semanticObject": "ZCustomMaster",
          "action": "maintain",
          "title": "{{ZCustomMaster-maintain.flpTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    },
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata4/iwbep/all/srvd/sap/zsd_dynamic_meta/0001/",
        "type": "OData",
        "settings": {
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "4.0"
        }
      },
      "auditLogService": {
        "uri": "/sap/opu/odata4/sap/zsb_audit_log_gsp14/srvd/sap/zsd_audit_log_gsp14/0001/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "rootView": {
      "viewName": "zapp.view.App",
      "type": "XML",
      "async": true,
      "id": "root"
    },
    "config": {
      "fullWidth": true
    },
    "dependencies": {
      "minUI5Version": "1.108.0",
      "libs": {
        "sap.f": {},
        "sap.ui.core": {},
        "sap.m": {},
        "sap.uxap": {},
        "sap.ui.comp": {},
        "sap.ui.table": {},
        "sap.viz": {},
        "sap.suite.ui.commons": {},
        "sap.suite.ui.microchart": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "zapp.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": false,
          "groupId": "$direct",
          "synchronizationMode": "None"
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      },
      "auditOData": {
        "dataSource": "auditLogService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.f.routing.Router",
        "viewType": "XML",
        "path": "zapp.view",
        "controlId": "appContainer",
        "transition": "slide",
        "async": true
      },
      "routes": [
        {
          "name": "RouteHome",
          "pattern": "",
          "target": "TargetHome"
        },
        {
          "name": "RouteMain",
          "pattern": "main",
          "target": "TargetMain"
        },
        {
          "name": "RouteMyRequests",
          "pattern": "my-requests",
          "target": "TargetMyRequests"
        },
        {
          "name": "RouteDashboard",
          "pattern": "dashboard",
          "target": "TargetDashboard"
        },
        {
          "name": "RouteApproval",
          "pattern": "approval",
          "target": "TargetApproval"
        },
        {
          "name": "RouteAuditLog",
          "pattern": "audit-log",
          "target": "TargetAuditLog"
        },
        {
          "name": "RouteRoleAssignment",
          "pattern": "role-assignment",
          "target": "TargetRoleAssignment"
        },
        {
          "name": "RouteObjectPage",
          "pattern": "detail/{tableName}/{newTable}",
          "target": [
            "TargetTwoColumnContainer",
            "DetailTable"
          ]
        },
        {
          "name": "Metadata",
          "pattern": "detail/{tableName}/metadata/{rowId}",
          "target": [
            "DetailTable",
            "MetadataTable"
          ]
        },
        {
          "name": "DetailData",
          "pattern": "detail/{tableName}/data/{rowId}",
          "target": [
            "DetailTable",
            "DataTable"
          ]
        }
      ],
      "targets": {
        "TargetHome": {
          "type": "View",
          "name": "Home",
          "id": "Home",
          "viewLevel": 1,
          "controlAggregation": "pages"
        },
        "TargetMain": {
          "type": "View",
          "name": "MainPage",
          "id": "MainPage",
          "viewLevel": 2,
          "controlAggregation": "pages"
        },
        "TargetMyRequests": {
          "type": "View",
          "name": "MyRequests",
          "id": "ViewMyRequests",
          "viewLevel": 2,
          "controlAggregation": "pages"
        },
        "TargetDashboard": {
          "type": "View",
          "name": "Dashboard",
          "id": "ViewDashboard",
          "viewLevel": 2,
          "controlAggregation": "pages"
        },
        "TargetApproval": {
          "type": "View",
          "name": "Approval",
          "id": "ViewApproval",
          "viewLevel": 2,
          "controlAggregation": "pages"
        },
        "TargetAuditLog": {
          "type": "View",
          "name": "AuditLog",
          "id": "ViewAuditLog",
          "viewLevel": 2,
          "controlAggregation": "pages"
        },
        "TargetRoleAssignment": {
          "type": "View",
          "name": "RoleAssignment",
          "id": "ViewRoleAssignment",
          "viewLevel": 2,
          "controlAggregation": "pages"
        },
        "TargetTwoColumnContainer": {
          "type": "View",
          "viewName": "TableContainer",
          "controlAggregation": "pages",
          "controlId": "appContainer",
          "viewLevel": 3
        },
        "DetailTable": {
          "viewName": "ObjectPage",
          "controlAggregation": "beginColumnPages",
          "parent": "TargetTwoColumnContainer",
          "controlId": "flexibleColumnLayout"
        },
        "MetadataTable": {
          "viewName": "Metadata",
          "controlAggregation": "midColumnPages",
          "parent": "TargetTwoColumnContainer",
          "controlId": "flexibleColumnLayout"
        },
        "DataTable": {
          "viewName": "DetailData",
          "controlAggregation": "midColumnPages",
          "parent": "TargetTwoColumnContainer",
          "controlId": "flexibleColumnLayout"
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}