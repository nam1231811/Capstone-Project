{
  "_version": "1.82.0",
  "sap.app": {
    "id": "zapp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.20.4",
      "toolsId": "c2dad03e-fdf3-4d1a-8b4f-439157dc7858"
    },
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata4/iwbep/all/srvd/sap/zsd_dynamic_meta/0001/",
        "type": "OData",
        "settings": {
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "rootView": {
            "viewName": "zapp.view.App",
            "type": "XML",
            "async": false
        },
    "config": {
          "fullWidth": true
    },
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.f": {},
        "sap.ui.core": {},
        "sap.m": {},
				"sap.uxap": {},
        "sap.ui.comp": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "zapp.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": false,
          "groupId": "$direct"
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "path": "zapp.view",
        "controlId": "appContainer",
        "transition": "slide",
        "async": true
      },
      "routes": [
        {
          "name": "RouteMain",
          "pattern": "",
          "target": "TargetMain"
        },
        {
          "name": "RouteObjectPage",
          "pattern": "detail/{tableName}",
          "target": ["TargetTwoColumnContainer", "DetailTable"]
        },
        {
          "name": "Metadata",
          "pattern": "detail/{tableName}/metadata/{rowId}",
          "target": ["DetailTable", "MetadataTable"]
        },
        {
          "name": "DetailData",
          "pattern": "detail/{tableName}/data/{rowId}",
          "target": ["DetailTable", "DataTable"]
        }

      ],
      "targets": {
        "TargetMain": {
          "type": "View",
          "name": "MainPage",
          "id": "MainPage",
          "viewLevel": 1,
          "controlAggregation": "pages"
        },
        
        "TargetTwoColumnContainer": {
          "type": "View",
          "viewName": "TableContainer", 
          "controlAggregation": "pages",
          "controlId": "appContainer",
          "viewLevel": "2"
        },
        "DetailTable": {
          "viewName": "ObjectPage", 
          "controlAggregation": "beginColumnPages",
          "parent": "TargetTwoColumnContainer", 
          "controlId": "flexibleColumnLayout"
        },
        "MetadataTable": {
          "viewName": "Metadata", 
          "controlAggregation": "midColumnPages",
          "parent": "TargetTwoColumnContainer", 
          "controlId": "flexibleColumnLayout"
        },
        "DataTable": {
          "viewName": "DetailData", 
          "controlAggregation": "midColumnPages",
          "parent": "TargetTwoColumnContainer", 
          "controlId": "flexibleColumnLayout"
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
