<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	controllerName="zapp.controller.Metadata"
	xmlns="sap.uxap"
	xmlns:m="sap.m"
	xmlns:f="sap.f"
	xmlns:form="sap.ui.layout.form"
	xmlns:l="sap.ui.layout">
	<ObjectPageLayout
		id="MetadataObjectPage"
		showTitleInHeaderContent="true"
		alwaysShowContentHeader="false"
		preserveHeaderStateOnScroll="false"
		headerContentPinnable="true"
		isChildPage="true"
		upperCaseAnchorBar="false">
		<headerTitle>
			
			<ObjectPageDynamicHeaderTitle>
				<actions>
					<m:Button
						text="Cancel"
						type="Transparent"
						press=".onRollback"/>
				</actions>
			</ObjectPageDynamicHeaderTitle>
		</headerTitle>

         <headerContent>
            <m:FlexBox wrap="Wrap" alignItems="Center">

                <m:Avatar
                    src="sap-icon://employee"
                    displaySize="L"
                    displayShape="Square"
                    class="sapUiMediumMarginEnd"/>

                <l:VerticalLayout class="sapUiMediumMarginEnd">
                    <m:Label text="Category"/>
                    <m:ObjectStatus
                        text="Z-Table"
                        state="Information"/>
                </l:VerticalLayout>

                <l:VerticalLayout class="sapUiMediumMarginEnd" >
                    <m:Label text="Table Name"/>
                    <m:ObjectStatus
                        text="{metadata>/FieldName/tableName}"
                        state="Success"/>
                </l:VerticalLayout>

                <l:VerticalLayout class="sapUiMediumMarginEnd" >
					<l:content >
                    	<m:Label text="Mandatory Field"/>
                    	<m:ObjectStatus
                    	    text="{metadata>/FieldName/keyflag}"
                    	    state="None"/>
					</l:content>
                </l:VerticalLayout>

                <l:VerticalLayout >
					<l:content >
                    	<m:Label text="Position"/>
                    	<m:ObjectStatus
                    	    text="{metadata>/FieldName/field_pos}"
                    	    state="None"/>
					</l:content>
                </l:VerticalLayout>

            </m:FlexBox>
        </headerContent>
		<sections>
			<ObjectPageSection title="General Information">
				<subSections>
					<ObjectPageSubSection>
						<blocks>
							<form:SimpleForm
								maxContainerCols="2"
								editable="false"
								layout="ResponsiveGridLayout"
								labelSpanL="12"
								labelSpanM="12"
								emptySpanL="0"
								emptySpanM="0"
								columnsL="1"
								columnsM="1">
								<form:content >
                                    <l:Grid 
                                        binding="{metadata>/FieldName}" 
                                        defaultSpan="XL4 L4 M4 S12" 
                                        vSpacing="1" 
                                        class="sapUiSmallMargin">
                                        <l:content>
                                            <m:VBox class="sapUiSmallMarginBottom">
                                                <m:Label 
                                                    text="Field Name: " 
                                                    design="Bold" 
                                                    class="sapUiTinyMarginBottom" />

                                                <m:Text text="{metadata>fieldname}"/>
                                            </m:VBox>

                                            <m:VBox class="sapUiSmallMarginBottom">
                                                <m:Label 
                                                    text="Data Type: " 
                                                    design="Bold" 
                                                    class="sapUiTinyMarginBottom" />

                                                <m:Text  text="{metadata>datatype}"/>
                                            </m:VBox>

                                            <m:VBox class="sapUiSmallMarginBottom">
                                                <m:Label 
                                                    text="Length: " 
                                                    design="Bold" 
                                                    class="sapUiTinyMarginBottom" />

                                                <m:Text  text="{metadata>leng}"/>
                                            </m:VBox>

                                            <m:VBox class="sapUiSmallMarginBottom">
                                                <m:Label 
                                                    text="Decimals: " 
                                                    design="Bold" 
                                                    class="sapUiTinyMarginBottom" />

                                                <m:Text  text="{metadata>decimals}"/>
                                            </m:VBox>
											
                                            <m:VBox class="sapUiSmallMarginBottom">
                                                <m:Label 
                                                    text="Display Label: " 
                                                    design="Bold" 
                                                    class="sapUiTinyMarginBottom" />

                                                <m:Text  text="{metadata>scrtextM}"/>
                                            </m:VBox>
											
                                            <m:VBox class="sapUiSmallMarginBottom">
                                                <m:Label 
                                                    text="Value Help: " 
                                                    design="Bold" 
                                                    class="sapUiTinyMarginBottom" />

                                                <m:Text  text="{metadata>hasValueHelp}"/>
                                            </m:VBox>
                                        </l:content>
                                    </l:Grid>
                                </form:content>
							</form:SimpleForm>
						</blocks>
					</ObjectPageSubSection>
				</subSections>
			</ObjectPageSection>
		</sections>
    </ObjectPageLayout>

</mvc:View>