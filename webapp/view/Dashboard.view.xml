<mvc:View
    controllerName="zapp.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:layout="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    displayBlock="true">
    
    <Page title="Dashboard Admin" showNavButton="true" navButtonPress=".onNavBack" backgroundDesign="List">
        <content>
            <layout:Grid defaultSpan="XL12 L12 M12 S12" class="sapUiSmallMarginTop">
                
                <HBox width="100%" justifyContent="SpaceAround" class="sapUiSmallMarginBottom">
                    <GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="Tổng số bảng quản lý" subheader="Toàn hệ thống" press="onPressKPI">
                        <TileContent>
                            <NumericContent value="{dash>/kpi/totalTables}" valueColor="Good" indicator="Up" />
                        </TileContent>
                    </GenericTile>
                    <GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="Record thay đổi hôm nay" subheader="Real-time" press="onPressKPI">
                        <TileContent>
                            <NumericContent value="{dash>/kpi/changedToday}" valueColor="Critical" indicator="Up" />
                        </TileContent>
                    </GenericTile>
                    <GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="Tổng Data đang có" subheader="Tất cả bảng Z" press="onPressKPI">
                        <TileContent>
                            <NumericContent value="{dash>/kpi/totalRecords}" valueColor="Neutral" />
                        </TileContent>
                    </GenericTile>
                </HBox>

                <f:Card>
                    <f:header>
                        <card:Header title="Tần suất thay đổi dữ liệu" subtitle="Thống kê Create/Update/Delete 7 ngày qua" iconSrc="sap-icon://line-chart"/>
                    </f:header>
                    <f:content>
                        <viz:VizFrame id="idLineChart" uiConfig="{applicationSet:'fiori'}" vizType="line" width="100%" height="300px" vizProperties="{title: {visible: false}}">
                            <viz:dataset>
                                <viz.data:FlattenedDataset data="{dash>/lineData}">
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition name="Date" value="{dash>date}" />
                                    </viz.data:dimensions>
                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition name="Create" value="{dash>create}" />
                                        <viz.data:MeasureDefinition name="Update" value="{dash>update}" />
                                        <viz.data:MeasureDefinition name="Delete" value="{dash>delete}" />
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Create,Update,Delete" />
                                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Date" />
                            </viz:feeds>
                        </viz:VizFrame>
                    </f:content>
                </f:Card>

                <f:Card>
                    <f:header>
                        <card:Header title="Top 5 Users tương tác" subtitle="Dựa trên số lần thay đổi dữ liệu" iconSrc="sap-icon://bar-chart"/>
                    </f:header>
                    <f:content>
                        <viz:VizFrame id="idBarChart" uiConfig="{applicationSet:'fiori'}" vizType="column" width="100%" height="300px" vizProperties="{title: {visible: false}}">
                            <viz:dataset>
                                <viz.data:FlattenedDataset data="{dash>/topUsers}">
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition name="User" value="{dash>user}" />
                                    </viz.data:dimensions>
                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition name="Action Count" value="{dash>actions}" />
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Action Count" />
                                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="User" />
                            </viz:feeds>
                        </viz:VizFrame>
                    </f:content>
                </f:Card>

                <f:Card height="100%">  
                    <f:layoutData>
                        <layout:GridData span="XL6 L6 M12 S12" />
                    </f:layoutData>
                    <f:header>
                        <card:Header title="Cảnh báo Data Quality" subtitle="Tỉ lệ dữ liệu trống tại các trường bắt buộc" iconSrc="sap-icon://pie-chart" statusText="Warning"/>
                    </f:header>
                    <f:content>
                        <VBox class="sapUiSmallMargin" width="100%" alignItems="Stretch">
                            
                            <SearchField placeholder="Nhập tên bảng (VD: ZEMPLOYEE_105)..." search=".onSearchTableQuality" width="100%" class="sapUiTinyMarginBottom"/>
                            
                            <viz:VizFrame id="idPieChart" uiConfig="{applicationSet:'fiori'}" vizType="donut" width="100%" height="320px" 
                                vizProperties="{
                                    title: {visible: false},
                                    legendGroup: {layout: {position: 'right'}},
                                    plotArea: { dataLabel: { visible: true, type: 'value' } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{dash>/pieData}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Trạng thái" value="{dash>status}" />
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Số lượng" value="{dash>count}" />
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="size" type="Measure" values="Số lượng" />
                                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Trạng thái" />
                                </viz:feeds>
                            </viz:VizFrame>
                            
                        </VBox>
                    </f:content>
                </f:Card>

                <f:Card height="100%">
                    <f:layoutData>
                        <layout:GridData span="XL6 L6 M12 S12" />
                    </f:layoutData>
                    <f:header>
                        <card:Header title="Log thay đổi gần nhất" subtitle="Top 5 actions (Click để xem chi tiết)" iconSrc="sap-icon://history"/>
                    </f:header>
                    <f:content>
                        <List items="{dash>/recentLogs}" class="sapUiSmallMarginBottom">
                            <StandardListItem 
                                title="Bảng: {dash>tableName}" 
                                description="{dash>action} by {dash>user} lúc {dash>time}" 
                                info="{dash>status}" 
                                infoState="{= ${dash>action} === 'CREATE' ? 'Success' : (${dash>action} === 'DELETE' ? 'Error' : 'Warning') }" 
                                type="Navigation" 
                                press=".onRecentLogPress" />
                        </List>
                    </f:content>
                </f:Card>

            </layout:Grid>
        </content>
    </Page>
</mvc:View>