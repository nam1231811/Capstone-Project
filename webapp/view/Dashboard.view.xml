<mvc:View
    controllerName="zapp.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:layout="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:core="sap.ui.core"
    xmlns:mc="sap.suite.ui.microchart"
    displayBlock="true"
    height="100%">
    
    <f:DynamicPage id="pageDashboard" toggleHeaderOnTitleClick="true" headerExpanded="true" class="sapUiNoContentPadding">
        
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Admin Dashboard" level="H2" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <layout:Grid defaultSpan="XL4 L4 M4 S12" hSpacing="1" vSpacing="1">
                    <f:Card width="100%" class="hoverableCard">
                        <f:content>
                            <List showSeparators="None">
                                <CustomListItem type="Active" press=".onPressKPI">
                                    <customData>
                                        <core:CustomData key="kpiTitle" value="Total of Custom Tables" />
                                    </customData>
                                    <HBox width="100%" justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMargin">
                                        <HBox alignItems="Center">
                                            <core:Icon src="sap-icon://grid" size="2.5rem" class="sapUiMediumMarginEnd" color="#2b7c2b" />
                                            <VBox>
                                                <Title text="Total Custom Tables" level="H4"/>
                                                <Text text="In audit log table" class="sapUiMutedText"/>
                                            </VBox>
                                        </HBox>
                                        <Title text="{dash>/kpi/totalTables}" level="H1" titleStyle="H1" class="sapThemeGoodText sapUiLargeMarginEnd" />
                                    </HBox>
                                </CustomListItem>
                            </List>
                        </f:content>
                    </f:Card>
                    
                    <f:Card width="100%" class="hoverableCard">
                        <f:content>
                            <List showSeparators="None">
                                <CustomListItem type="Active" press=".onPressKPI">
                                    <customData>
                                        <core:CustomData key="kpiTitle" value="Total of Changes Today" />
                                    </customData>
                                    <HBox width="100%" justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMargin">
                                        <HBox alignItems="Center">
                                            <core:Icon src="sap-icon://history" size="2.5rem" class="sapUiMediumMarginEnd" color="#e9730c" />
                                            <VBox>
                                                <Title text="Total Changes Today" level="H4"/>
                                                <Text text="Real-time updates" class="sapUiMutedText"/>
                                            </VBox>
                                        </HBox>
                                        <Title text="{dash>/kpi/changedToday}" level="H1" titleStyle="H1" class="sapThemeCriticalText sapUiLargeMarginEnd" />
                                    </HBox>
                                </CustomListItem>
                            </List>
                        </f:content>
                    </f:Card>
                    
                    <f:Card width="100%" class="hoverableCard">
                        <f:content>
                            <List showSeparators="None">
                                <CustomListItem type="Active" press=".onPressKPI">
                                    <customData>
                                        <core:CustomData key="kpiTitle" value="Total of Data" />
                                    </customData>
                                    <HBox width="100%" justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMargin">
                                        <HBox alignItems="Center">
                                            <core:Icon src="sap-icon://product" size="2.5rem" class="sapUiMediumMarginEnd" color="#107e3e" />
                                            <VBox>
                                                <Title text="Total Records" level="H4"/>
                                                <Text text="In custom tables" class="sapUiMutedText"/>
                                            </VBox>
                                        </HBox>
                                        <Title text="{dash>/kpi/totalRecords}" level="H1" titleStyle="H1" class="sapThemeNeutralText sapUiLargeMarginEnd" />
                                    </HBox>
                                </CustomListItem>
                            </List>
                        </f:content>
                    </f:Card>
                </layout:Grid>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <layout:Grid defaultSpan="XL12 L12 M12 S12" vSpacing="1" hSpacing="1" class="sapUiSmallMargin">
                
                <f:Card id="cardLineChart">
                    <f:header>
                        <card:Header title="Data Change Frequency" subtitle="Statistics of actions in the last 7 days" iconSrc="sap-icon://line-chart" />
                    </f:header>
                    <f:content>
                        <VBox width="100%"> 
                            <Toolbar style="Clear" class="sapUiSmallMarginBeginEnd">
                                <ToolbarSpacer />
                                <SearchField placeholder="Filter by User ID..." search=".onUserFilterChange" width="250px" class="sapUiTinyMarginTopBottom" />
                            </Toolbar>
                            <viz:VizFrame id="idLineChart" selectData=".onLineChartSelect" uiConfig="{applicationSet:'fiori'}" vizType="line" width="100%" height="300px" vizProperties="{title: {visible: false}}">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{dash>/lineData}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Date" value="{dash>CHART_DATE}" />
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Create" value="{dash>CREATE_COUNT}" />
                                            <viz.data:MeasureDefinition name="Update" value="{dash>UPDATE_COUNT}" />
                                            <viz.data:MeasureDefinition name="Delete" value="{dash>DELETE_COUNT}" />
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Create,Update,Delete" />
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Date" />
                                </viz:feeds>
                            </viz:VizFrame>
                        </VBox>
                    </f:content>
                </f:Card>

                <f:Card id="cardBarChart" height="450px">
                    <f:layoutData>
                        <layout:GridData span="XL6 L6 M12 S12" />
                    </f:layoutData>
                    <f:header>
                        <card:Header title="Top Users" subtitle="Based on number of actions" iconSrc="sap-icon://bar-chart"/>
                    </f:header>
                    <f:content>
                        <viz:VizFrame id="idBarChart" selectData=".onTopUserSelect" uiConfig="{applicationSet:'fiori'}" vizType="column" width="100%" height="350px" 
                            vizProperties="{
                                title: {visible: false}, 
                                legend: {visible: false}, 
                                valueAxis: {title: {visible: false}}, 
                                categoryAxis: {title: {visible: false}}
                            }">
                            <viz:dataset>
                                <viz.data:FlattenedDataset data="{dash>/topUsers}">
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition name="Changed By" value="{dash>CHANGED_BY}" />
                                    </viz.data:dimensions>
                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition name="Action Count" value="{dash>ACTION_COUNT}" />
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Action Count" />
                                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Changed By" />
                            </viz:feeds>
                        </viz:VizFrame>
                    </f:content>
                </f:Card>

                <f:Card id="dataManagementCard" height="450px">
                    <f:layoutData>
                        <layout:GridData span="XL6 L6 M12 S12" />
                    </f:layoutData>
                    <f:header>
                        <card:Header title="Data Management" subtitle="Manage and analyze your data" iconSrc="sap-icon://pie-chart" statusText="{= 'Measured ' + ${dash>/qualityPercentage} + '% valid'}"/>
                    </f:header>
                    <f:content>
                        <VBox width="100%">
                            <Toolbar style="Clear" class="sapUiTinyMarginTop sapUiSmallMarginBeginEnd">
                                <Input id="searchTableInput" 
                                       placeholder="Enter table name..." 
                                       showValueHelp="true" 
                                       valueHelpRequest=".onValueHelpRequest" 
                                       submit=".onSearchTableQuality" 
                                       width="60%" />
                                <Button icon="sap-icon://refresh" press=".onResetPieChart" type="Transparent" tooltip="Reload Default"/>
                                <ToolbarSpacer />
                            </Toolbar>
                            
                            <HBox width="100%" class="sapUiSmallMarginTop sapUiSmallMarginBeginEnd">
                                
                                <VBox width="55%" class="sapUiSmallMarginEnd">
                                    <viz:VizFrame id="idPieChart" uiConfig="{applicationSet:'fiori'}" vizType="donut" width="100%" height="220px" 
                                        vizProperties="{
                                            title: {visible: false},
                                            legendGroup: { layout: { position: 'bottom', alignment: 'center' } }
                                        }">
                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{dash>/pieData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Status" value="{dash>status}" />
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Count" value="{dash>count}" />
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>
                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="size" type="Measure" values="Count" />
                                            <viz.feeds:FeedItem uid="color" type="Dimension" values="Status" />
                                        </viz:feeds>
                                    </viz:VizFrame>
                                    
                                    <HBox width="100%" alignItems="Center" justifyContent="Center" class="sapUiTinyMarginTop">
                                        <mc:RadialMicroChart alignContent="Center" size="M" percentage="{dash>/qualityPercentage}" valueColor="{dash>/qualityColor}" class="sapUiSmallMarginEnd"/>
                                        <Label text="Data Quality" design="Bold" wrapping="true"/>
                                    </HBox>
                                </VBox>

                                <VBox width="45%" visible="{= ${dash>/dataInsight/totalRows} > 0 }">
                                    <Title text="Data Insight Information" level="H6" class="sapUiTinyMarginBottom" />
                                    <ObjectStatus text="Total: {dash>/dataInsight/totalRows} records" state="Information" class="sapUiSmallMarginBottom" />
                                    
                                    <Label text="Top empty columns:" design="Bold" class="sapUiTinyMarginTop" />
                                    <List items="{dash>/dataInsight/topMissingCols}" showSeparators="None" noDataText="Fully populated.">
                                        <items>
                                            <StandardListItem title="{dash>col}" description="{dash>count} missing fields" infoState="Warning" />
                                        </items>
                                    </List>
                                </VBox>
                                
                            </HBox>
                        </VBox>
                    </f:content>
                </f:Card>

            </layout:Grid>
        </f:content>

        <f:dependents>
            <Popover id="kpiPopover" title="{dash>/popoverTitle}" contentWidth="320px" placement="Bottom">
                <content>
                    <VBox visible="{= ${dash>/popoverType} === 'CHANGES' }" class="sapUiSmallMargin">
                        <ObjectStatus text="Create: {dash>/popoverChanges/CREATE_COUNT}" state="Success" icon="sap-icon://add-document" class="sapUiTinyMarginBottom" />
                        <ObjectStatus text="Update: {dash>/popoverChanges/UPDATE_COUNT}" state="Warning" icon="sap-icon://edit" class="sapUiTinyMarginBottom" />
                        <ObjectStatus text="Delete: {dash>/popoverChanges/DELETE_COUNT}" state="Error" icon="sap-icon://delete" />
                    </VBox>
                    <List visible="{= ${dash>/popoverType} === 'TABLES' }" items="{dash>/popoverTables}" busy="{dash>/isPopoverTableBusy}" showSeparators="Inner" noDataText="No recent activity">
                        <items>
                            <ObjectListItem title="{dash>name}" icon="sap-icon://table-chart" />
                        </items>
                    </List>
                    <VBox visible="{= ${dash>/popoverType} === 'RECORDS' }" class="sapUiSmallMargin">
                        <Text text="Average records per table:" class="sapUiTinyMarginBottom" />
                        <ObjectNumber number="{dash>/popoverAvg}" unit="Records / Table" state="Success" />
                    </VBox>
                </content>
                <endButton>
                    <Button icon="sap-icon://decline" type="Transparent" press=".onCloseKPIPopover" />
                </endButton>
            </Popover>

            <Dialog id="detailDialog" title="{dash>/detailTitle}" contentWidth="400px">
                <content>
                    <VBox class="sapUiSmallMargin" busy="{dash>/isDetailBusy}">
                        <HBox visible="{= ${dash>/detailRejectRate} !== null }" class="sapUiSmallMarginBottom" alignItems="Center">
                            <Label text="Request Reject Rate:" design="Bold" class="sapUiSmallMarginEnd"/>
                            <ObjectStatus text="{dash>/detailRejectRate}%" state="{= ${dash>/detailRejectRate} > 10 ? 'Error' : 'Success' }" icon="sap-icon://sys-cancel-2" />
                        </HBox>
                        <Title text="List of affected tables" level="H6" />
                        <List items="{dash>/detailTables}" showSeparators="Inner" noDataText="No tables found">
                            <StandardListItem title="{dash>name}" description="{= ${dash>count} ? 'Number of changes: ' + ${dash>count} : ''}" icon="sap-icon://table-view"/>
                        </List>
                    </VBox>
                </content>
                <beginButton>
                    <Button text="Close" type="Reject" press=".onCloseDetailDialog" />
                </beginButton>
            </Dialog>
        </f:dependents>

    </f:DynamicPage>
</mvc:View>