<mvc:View
    controllerName="zapp.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:layout="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%">
    
    <f:DynamicPage id="pageDashboard" toggleHeaderOnTitleClick="true" headerExpanded="true" class="sapUiNoContentPadding">
        
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Admin Dashboard" level="H2" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <layout:Grid defaultSpan="XL4 L4 M4 S12" hSpacing="1" vSpacing="1">
                    
                    <f:Card width="100%" class="hoverableCard">
                        <f:content>
                            <List showSeparators="None">
                                <CustomListItem type="Active" press=".onPressKPI">
                                    <customData>
                                        <core:CustomData key="kpiTitle" value="Total of Custom Tables" />
                                    </customData>
                                    <HBox width="100%" justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMargin">
                                        
                                        <HBox alignItems="Center">
                                            <core:Icon src="sap-icon://grid" size="2.5rem" class="sapUiMediumMarginEnd" color="#2b7c2b" />
                                            <VBox>
                                                <Title text="Total Custom Tables" level="H4"/>
                                                <Text text="In audit log table" class="sapUiMutedText"/>
                                            </VBox>
                                        </HBox>
                                        
                                        <Title text="{dash>/kpi/totalTables}" level="H1" titleStyle="H1" class="sapThemeGoodText sapUiLargeMarginEnd" />
                                    
                                    </HBox>
                                </CustomListItem>
                            </List>
                        </f:content>
                    </f:Card>
                    
                    <f:Card width="100%" class="hoverableCard">
                        <f:content>
                            <List showSeparators="None">
                                <CustomListItem type="Active" press=".onPressKPI">
                                    <customData>
                                        <core:CustomData key="kpiTitle" value="Total of Changes Today" />
                                    </customData>
                                    <HBox width="100%" justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMargin">
                                        
                                        <HBox alignItems="Center">
                                            <core:Icon src="sap-icon://history" size="2.5rem" class="sapUiMediumMarginEnd" color="#e9730c" />
                                            <VBox>
                                                <Title text="Total Changes Today" level="H4"/>
                                                <Text text="Real-time updates" class="sapUiMutedText"/>
                                            </VBox>
                                        </HBox>
                                        
                                        <Title text="{dash>/kpi/changedToday}" level="H1" titleStyle="H1" class="sapThemeCriticalText sapUiLargeMarginEnd" />
                                    
                                    </HBox>
                                </CustomListItem>
                            </List>
                        </f:content>
                    </f:Card>
                    
                    <f:Card width="100%" class="hoverableCard">
                        <f:content>
                            <List showSeparators="None">
                                <CustomListItem type="Active" press=".onPressKPI">
                                    <customData>
                                        <core:CustomData key="kpiTitle" value="Total of Data" />
                                    </customData>
                                    <HBox width="100%" justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMargin">
                                        
                                        <HBox alignItems="Center">
                                            <core:Icon src="sap-icon://product" size="2.5rem" class="sapUiMediumMarginEnd" color="#107e3e" />
                                            <VBox>
                                                <Title text="Total Records" level="H4"/>
                                                <Text text="In custom tables" class="sapUiMutedText"/>
                                            </VBox>
                                        </HBox>
                                        
                                        <Title text="{dash>/kpi/totalRecords}" level="H1" titleStyle="H1" class="sapThemeNeutralText sapUiLargeMarginEnd" />
                                    
                                    </HBox>
                                </CustomListItem>
                            </List>
                        </f:content>
                    </f:Card>

                </layout:Grid>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <layout:Grid defaultSpan="XL12 L12 M12 S12" vSpacing="1" hSpacing="1" class="sapUiSmallMargin">
                
                <f:Card id="cardLineChart">
                    <f:header>
                        <card:Header title="Data Change Frequency" subtitle="Statistics of Create/Update/Delete over the last 7 days" iconSrc="sap-icon://line-chart"/>
                    </f:header>
                    <f:content>
                        <viz:VizFrame id="idLineChart" uiConfig="{applicationSet:'fiori'}" vizType="line" width="100%" height="300px" vizProperties="{title: {visible: false}}">
                            <viz:dataset>
                                <viz.data:FlattenedDataset data="{dash>/lineData}">
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition name="Date" value="{dash>date}" />
                                    </viz.data:dimensions>
                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition name="Create" value="{dash>create}" />
                                        <viz.data:MeasureDefinition name="Update" value="{dash>update}" />
                                        <viz.data:MeasureDefinition name="Delete" value="{dash>delete}" />
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Create,Update,Delete" />
                                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Date" />
                            </viz:feeds>
                        </viz:VizFrame>
                    </f:content>
                </f:Card>

                <f:Card id="cardBarChart">
                    <f:header>
                        <card:Header title="Top Users With Most Changes" subtitle="Based on the number of data changes" iconSrc="sap-icon://bar-chart"/>
                    </f:header>
                    <f:content>
                        <viz:VizFrame id="idBarChart" uiConfig="{applicationSet:'fiori'}" vizType="column" width="100%" height="300px" vizProperties="{title: {visible: false}}">
                            <viz:dataset>
                                <viz.data:FlattenedDataset data="{dash>/topUsers}">
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition name="User" value="{dash>user}" />
                                    </viz.data:dimensions>
                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition name="Action Count" value="{dash>actions}" />
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Action Count" />
                                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="User" />
                            </viz:feeds>
                        </viz:VizFrame>
                    </f:content>
                </f:Card>

                <f:Card id="dataManagementCard" height="420px">
                    <f:layoutData>
                        <layout:GridData span="XL6 L6 M12 S12" />
                    </f:layoutData>
                    <f:header>
                        <card:Header title="Data Management" subtitle="Manage and analyze your data" iconSrc="sap-icon://pie-chart" statusText="Warning"/>
                    </f:header>
                    <f:content>
                        <VBox width="100%" height="100%">
                            <Toolbar style="Clear" class="sapUiTinyMarginTop sapUiSmallMarginBeginEnd">
                                <Input id="searchTableInput" 
                                       placeholder="Enter table name..." 
                                       showValueHelp="true" 
                                       valueHelpRequest=".onValueHelpRequest" 
                                       submit=".onSearchTableQuality" 
                                       width="50%" />
                                <Button icon="sap-icon://refresh" press=".onResetPieChart" type="Transparent" tooltip="Reload Default Chart"/>
                                <ToolbarSpacer />
                            </Toolbar>
                            
                            <viz:VizFrame id="idPieChart" uiConfig="{applicationSet:'fiori'}" vizType="donut" width="100%" height="280px" 
                                vizProperties="{
                                    title: {visible: false},
                                    legendGroup: {layout: {position: 'left'}}
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{dash>/pieData}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Trạng thái" value="{dash>status}" />
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Số lượng" value="{dash>count}" />
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="size" type="Measure" values="Số lượng" />
                                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Trạng thái" />
                                </viz:feeds>
                            </viz:VizFrame>
                        </VBox>
                    </f:content>
                </f:Card>

                <f:Card id="cardRecentLogs" height="420px">
                    <f:layoutData>
                        <layout:GridData span="XL6 L6 M12 S12" />
                    </f:layoutData>
                    <f:header>
                        <card:Header title="Recent Changes" subtitle="Top 5 recent actions" iconSrc="sap-icon://history"/>
                    </f:header>
                    <f:content>
                        <ScrollContainer width="100%" height="320px" vertical="true">
                            <List items="{dash>/recentLogs}" showSeparators="Inner" width="100%">
                                <CustomListItem type="Navigation" press=".onRecentLogPress" class="sapUiSmallMarginBottom sapUiShadow1">
                                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMargin">
                                        
                                        <HBox alignItems="Center">
                                            <core:Icon 
                                                src="{= ${dash>action} === 'CREATE' ? 'sap-icon://add-document' : (${dash>action} === 'UPDATE' ? 'sap-icon://edit' : 'sap-icon://delete') }"
                                                size="1.5rem"
                                                color="{= ${dash>action} === 'CREATE' ? '#2b7c2b' : (${dash>action} === 'UPDATE' ? '#e9730c' : '#bb0000') }"
                                                class="sapUiMediumMarginEnd" />
                                            
                                            <VBox>
                                                <Title text="Table: {dash>tableName}" level="H5" />
                                                
                                                <HBox class="sapUiTinyMarginTop">
                                                    <Label text="By:" design="Bold" class="sapUiTinyMarginEnd"/>
                                                    <Text text="{dash>user}" />
                                                </HBox>
                                                
                                                <HBox class="sapUiTinyMarginTop">
                                                    <Label text="At:" design="Bold" class="sapUiTinyMarginEnd"/>
                                                    <Text text="{dash>time}" />
                                                </HBox>
                                            </VBox>
                                        </HBox>

                                        <VBox alignItems="End">
                                            <ObjectStatus 
                                                text="{dash>action}" 
                                                state="{= ${dash>action} === 'CREATE' ? 'Success' : (${dash>action} === 'UPDATE' ? 'Warning' : 'Error') }"
                                                inverted="true" />
                                        </VBox>

                                    </HBox>
                                </CustomListItem>
                            </List>
                        </ScrollContainer>
                    </f:content>
                </f:Card>

            </layout:Grid>
        </f:content>
    </f:DynamicPage>
</mvc:View>