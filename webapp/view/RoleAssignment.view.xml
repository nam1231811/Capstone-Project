<mvc:View
    controllerName="zapp.controller.RoleAssignment"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:layout="sap.ui.layout"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    
    <f:DynamicPage id="roleAssignmentPageId" headerExpanded="true" class="sapUiResponsiveContentPadding">
        
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Role Assignment" level="H2"/>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <layout:Grid defaultSpan="XL12 L12 M12 S12" class="sapUiSmallMarginTop">
                
                <f:Card>
                    <f:content>
                        <HBox width="100%" alignItems="Center" justifyContent="SpaceBetween" class="sapUiSmallMargin">
                            
                            <HBox alignItems="Center">
                                <Avatar src="sap-icon://key-user-settings" displaySize="S" backgroundColor="Transparent" class="sapUiSmallMarginEnd"/>
                                <VBox>
                                    <Title text="Search &amp; Filter" level="H6" />
                                    <Text text="Search and assign system roles" />
                                </VBox>
                            </HBox>

                            <HBox alignItems="Center" class="sapUiSmallMarginEnd">
                                <SearchField id="searchUser" placeholder="Search Username or Name..." search=".onSearchUser" width="300px" class="sapUiSmallMarginEnd" />
                                
                                <ComboBox id="filterRole" placeholder="Filter by Role..." selectionChange=".onSearchUser">
                                    <core:Item key="ALL" text="All Roles" />
                                    <core:Item key="Admin" text="Admin" />
                                    <core:Item key="Manager" text="Manager" />
                                    <core:Item key="Clerk" text="Clerk" />
                                </ComboBox>
                            </HBox>

                        </HBox>
                    </f:content>
                </f:Card>

                <f:Card>
                    <f:content>
                        <Table id="usersTable" 
                               items="{/UserRoleList}"
                               noDataText="Loading data or user not found..."
                               alternateRowColors="true"
                               class="sapUiTinyMarginBottom">
                               
                            <headerToolbar>
                                <Toolbar style="Clear" height="auto" class="sapUiSmallMarginTopBottom">
                                    <Avatar src="sap-icon://group" displaySize="S" backgroundColor="Transparent" class="sapUiTinyMarginEnd"/>
                                    
                                    <VBox class="sapUiTinyMarginTopBottom">
                                        <Title text="System Users List" level="H5"/>
                                        <Text text="List of users from SAP system" />
                                    </VBox>
                                    
                                    <ToolbarSpacer />
                                    
                                    <HBox width="15%" justifyContent="Center">
                                        <Button text="Assign Role" type="Emphasized" icon="sap-icon://add-contact" press=".onOpenAssignDialog"/>
                                    </HBox>
                                    
                                </Toolbar>
                            </headerToolbar>

                            <columns>
                                <Column width="30%"><Label text="User Account" design="Bold"/></Column>
                                <Column width="15%"><Label text="Department" design="Bold"/></Column>
                                <Column width="25%"><Label text="Role" design="Bold"/></Column>
                                <Column width="15%"><Label text="Validity" design="Bold"/></Column>
                                <Column width="15%" hAlign="Center"><Label text="Action" design="Bold"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                <customData>
                                        <core:CustomData key="force1" value="{IsAdmin}" />
                                        <core:CustomData key="force2" value="{IsManager}" />
                                        <core:CustomData key="force3" value="{IsClerk}" />
                                    </customData>
                                    <cells>
                                        <HBox alignItems="Center">
                                            <Avatar src="sap-icon://person-placeholder" displaySize="XS" class="sapUiTinyMarginEnd" 
                                                    backgroundColor="{parts: [{path: 'IsAdmin'}, {path: 'IsManager'}, {path: 'IsClerk'}], formatter: '.formatterAvatarColor'}"/>
                                            <VBox justifyContent="Center">
                                                <Label text="{FullName}" design="Bold" visible="{= ${FullName} ? true : false }" />
                                                <Label text="{Username}" />
                                            </VBox>
                                        </HBox>
                                        
                                        <Label text="N/A" />
                                        
                                        <ObjectStatus 
                                            text="{parts: [{path: 'IsAdmin'}, {path: 'IsManager'}, {path: 'IsClerk'}], formatter: '.formatterRoleText'}" 
                                            icon="{parts: [{path: 'IsAdmin'}, {path: 'IsManager'}, {path: 'IsClerk'}], formatter: '.formatterRoleIcon'}"
                                            state="{parts: [{path: 'IsAdmin'}, {path: 'IsManager'}, {path: 'IsClerk'}], formatter: '.formatterRoleState'}" />

                                        <ObjectStatus 
                                            text="{ValidityText}" 
                                            state="{= ${ValidityText} === 'No expiration' ? 'Success' : (${ValidityText} === 'Unassigned' ? 'None' : (${ValidityText} === 'Expired' ? 'Error' : 'Warning')) }"
                                            class="sapUiTinyMarginTop"/>
                                        
                                        <HBox justifyContent="Center">
                                            <Button icon="sap-icon://edit" type="Transparent" tooltip="Edit Role" press=".onEditRole" class="sapUiTinyMarginEnd"/>     
                                            <Button icon="sap-icon://delete" type="Transparent" tooltip="Revoke Role" press=".onRevokeRole" 
                                                    enabled="{parts: [{path: 'IsAdmin'}, {path: 'IsManager'}, {path: 'IsClerk'}], formatter: '.formatterEnableDelete'}"/>
                                        </HBox>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </f:content>
                </f:Card>

            </layout:Grid>
        </f:content>

        <f:dependents>
            <Dialog 
                id="roleDialog"
                title="{roleLocal>/dialogTitle}"
                contentWidth="400px">
                <content>
                    <form:SimpleForm 
                        layout="ResponsiveGridLayout" 
                        labelSpanL="4" labelSpanM="4" 
                        emptySpanL="1" emptySpanM="1" 
                        columnsL="1" columnsM="1">
                        <form:content>
                            <Label text="User Account" required="true" />
                            <Input 
                                value="{roleLocal>/formData/userId}" 
                                placeholder="e.g., DEV-097..." 
                                enabled="{= !${roleLocal>/formData/isEditMode} }" />

                            <Label text="Assign Role" required="true" />
                            <Select 
                                selectedKey="{roleLocal>/formData/roleId}" 
                                width="100%">
                                <items>
                                    <core:Item key="" text="--- Select Role (Unassigned) ---" />
                                    <core:Item key="Admin" text="Admin (Full Access)" />
                                    <core:Item key="Manager" text="Manager (Approval)" />
                                    <core:Item key="Clerk" text="Clerk (Employee)" />
                                </items>
                            </Select>

                            <Label text="Expiration Date" />
                            <DatePicker 
                                value="{roleLocal>/formData/validTo}" 
                                valueFormat="yyyyMMdd" 
                                displayFormat="dd/MM/yyyy" 
                                placeholder="Leave blank = No expiration" />
                        </form:content>
                    </form:SimpleForm>
                </content>
                <beginButton>
                    <Button text="Save (Assign Role)" type="Emphasized" press=".onSaveRole" />
                </beginButton>
                <endButton>
                    <Button text="Cancel" press=".onCloseRoleDialog" />
                </endButton>
            </Dialog>
        </f:dependents>

    </f:DynamicPage>
</mvc:View>