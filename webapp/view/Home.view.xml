<mvc:View
    controllerName="zapp.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout">
    
    <Page id="homePage" title="Home Screen" showHeader="true" class="sapUiResponsivePadding--header">
        <content>
            
            <VBox class="sapUiSmallMargin">
                
                <Title 
                    text="Functional Apps" 
                    level="H2" 
                    titleStyle="H4" 
                    class="sapUiTinyMarginBottom sapUiTinyMarginBegin"/>
                
                <layout:HorizontalLayout allowWrapping="true">
                    
                    <GenericTile 
                        class="sapUiTinyMarginBegin sapUiTinyMarginTop" 
                        header="Custom Master Data" 
                        subheader="Maintenance" 
                        press=".onNavToApp">
                        <TileContent>
                            <ImageContent src="sap-icon://database"/>
                        </TileContent>
                    </GenericTile>

                    <GenericTile 
                        class="sapUiTinyMarginBegin sapUiTinyMarginTop" 
                        header="Dashboard" 
                        subheader="Analytics &amp; Reports" 
                        press=".onNavToDashboard">
                        <TileContent>
                            <ImageContent src="sap-icon://bpi-metrics"/> 
                        </TileContent>
                    </GenericTile>

                    <GenericTile 
                        class="sapUiTinyMarginBegin sapUiTinyMarginTop" 
                        header="Approval" 
                        subheader="Pending Requests" 
                        press=".onNavToApproval">
                        <TileContent>
                            <ImageContent src="sap-icon://sys-enter-2"/>
                        </TileContent>
                    </GenericTile>

                </layout:HorizontalLayout>
            </VBox>
            
        </content>
    </Page>
</mvc:View>