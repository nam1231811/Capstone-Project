<mvc:View
    controllerName="zapp.controller.Approval"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <f:DynamicPage id="approvalPageId" headerExpanded="true" class="sapUiResponsiveContentPadding">
        
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Approval Management" level="H2"/>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <VBox fitContainer="true" height="100%">
                
                <MessagePage 
                    id="accessDeniedPage"
                    visible="{= !(${auth>/isManager} || ${auth>/isAdmin}) }" 
                    showHeader="false"
                    icon="sap-icon://locked"
                    text="You do not have permission"
                    description="This feature is only available for Managers and Admins!"/>

                <VBox visible="{= ${auth>/isManager} || ${auth>/isAdmin} }" width="100%">
                    
                <OverflowToolbar height="3.5rem" class="sapUiSmallMarginBottom sapUiShadow1" design="Solid">
                        <Title text="Filter Action:" level="H4" class="sapUiTinyMarginEnd" />
                        <SegmentedButton id="actionFilterBar" selectionChange=".onActionFilterSelect" selectedKey="ALL">
                            <items>
                                <SegmentedButtonItem key="ALL" text="All" />
                                <SegmentedButtonItem key="CREATE" text="Create" icon="sap-icon://add" />
                                <SegmentedButtonItem key="UPDATE" text="Update" icon="sap-icon://edit" />
                                <SegmentedButtonItem key="DELETE" text="Delete" icon="sap-icon://delete" />
                            </items>
                        </SegmentedButton>

                        <ToolbarSpacer />

                        <SearchField id="searchRequestedBy" 
                                     placeholder="Search requester..." 
                                     width="250px" 
                                     showSearchButton="false"
                                     liveChange=".onSearchUser" 
                                     class="sapUiSmallMarginEnd"/>

                        <Button id="modeToggleBtn"
                                text="{= ${approval>/isPendingMode} ? 'Pending (' + ${approval>/pendingCount} + ')' : 'History (' + ${approval>/historyCount} + ')' }"
                                icon="{= ${approval>/isPendingMode} ? 'sap-icon://pending' : 'sap-icon://history' }"
                                type="Emphasized"
                                press=".onToggleMode" />
                    </OverflowToolbar>

                    <Table id="pendingTable" 
                        items="{approval>/pendingList}" 
                        noDataText="No pending approval requests"
                        sticky="ColumnHeaders"
                        class="sapUiSmallMarginBottom sapUiShadow1"
                        visible="{approval>/isPendingMode}">
                        <columns>
                            <Column width="15%"><Label text="No." design="Bold"/></Column>
                            <Column width="20%"><Label text="Data Table" design="Bold"/></Column>
                            <Column width="15%" hAlign="Center"><Label text="Action" design="Bold"/></Column>
                            <Column width="20%" demandPopin="true" minScreenWidth="Tablet"><Label text="Requested By" design="Bold"/></Column>
                            <Column width="20%" demandPopin="true" minScreenWidth="Desktop"><Label text="Requested At" design="Bold"/></Column>
                            <Column width="10%" hAlign="End"><Label text="Details" design="Bold"/></Column>
                        </columns>
                        <items>
                            <ColumnListItem type="Navigation" press=".onViewDiffDetail">
                                <cells>
                                    <Text text="{approval>indexNo}" class="sapUiMutedText" />
                                    <VBox>
                                        <Text text="{approval>tableName}"/>
                                        <Text text="ID: {approval>reqId}" visible="false" /> </VBox>
                                    <ObjectStatus text="{approval>action}" 
                                                state="{= ${approval>action} === 'CREATE' ? 'Success' : (${approval>action} === 'DELETE' ? 'Error' : 'Warning') }" 
                                                icon="{= ${approval>action} === 'CREATE' ? 'sap-icon://add' : (${approval>action} === 'DELETE' ? 'sap-icon://delete' : 'sap-icon://edit') }" 
                                                inverted="true" /> 
                                    <Text text="{approval>requestedBy}" />
                                    <Text text="{approval>requestedAt}" />
                                    <Button icon="sap-icon://compare" type="Transparent" press=".onViewDiffDetail"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>

                    <Table id="historyTable" 
                        items="{approval>/historyList}" 
                        noDataText="No history data available"
                        sticky="ColumnHeaders"
                        class="sapUiSmallMarginBottom sapUiShadow1"
                        visible="{= !${approval>/isPendingMode} }">
                        <columns>
                            <Column width="15%"><Label text="No." design="Bold"/></Column>
                            <Column width="15%" demandPopin="true" minScreenWidth="Tablet"><Label text="Data Table" design="Bold"/></Column>
                            <Column width="15%" demandPopin="true" minScreenWidth="Tablet"><Label text="Action" design="Bold"/></Column>
                            <Column width="20%"><Label text="Approval Status" design="Bold"/></Column>
                            <Column width="20%" demandPopin="true" minScreenWidth="Desktop"><Label text="Approved At" design="Bold"/></Column>
                            <Column width="15%" demandPopin="true" minScreenWidth="Desktop"><Label text="Approver" design="Bold"/></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{approval>indexNo}" class="sapUiMutedText" />
                                    <Text text="{approval>tableName}" />
                                    <ObjectStatus text="{approval>action}" 
                                                state="{= ${approval>action} === 'CREATE' ? 'Success' : (${approval>action} === 'DELETE' ? 'Error' : 'Warning') }" 
                                                inverted="true" />
                                    <ObjectStatus text="{approval>status}" 
                                                state="{= ${approval>status} === 'APPROVED' ? 'Success' : 'Error' }"
                                                icon="{= ${approval>status} === 'APPROVED' ? 'sap-icon://accept' : 'sap-icon://decline' }" 
                                                inverted="true" />
                                    <Text text="{approval>processedAt}" />
                                    <Text text="{approval>processedBy}" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>

                </VBox>
            </VBox>
        </f:content>

        <f:dependents>
            <Dialog 
                id="diffDialog"
                title="Approval Detail" 
                contentWidth="800px" 
                contentHeight="500px" 
                resizable="true" 
                draggable="true">
                
                <customHeader>
                    <Toolbar>
                        <Title text="Review Request" />
                        <ToolbarSpacer />
                        <Button icon="sap-icon://decline" type="Transparent" press=".onCloseDiffDialog" />
                    </Toolbar>
                </customHeader>

                <content>
                    <VBox>
                        <ObjectHeader 
                            title="Target Table: {approval>/currentDetail/tableName}" 
                            icon="sap-icon://table-view" 
                            responsive="true" 
                            fullScreenOptimized="true">
                            <statuses>
                                <ObjectStatus 
                                    text="{approval>/currentDetail/action}"
                                    state="{= ${approval>/currentDetail/action} === 'CREATE' ? 'Success' : (${approval>/currentDetail/action} === 'DELETE' ? 'Error' : 'Warning') }"
                                    icon="{= ${approval>/currentDetail/action} === 'CREATE' ? 'sap-icon://add' : (${approval>/currentDetail/action} === 'DELETE' ? 'sap-icon://delete' : 'sap-icon://edit') }"
                                    inverted="true" />
                            </statuses>
                        </ObjectHeader>

                        <MessageStrip 
                            text="Please review the data differences below before making a decision" 
                            type="Information" 
                            showIcon="true" 
                            class="sapUiSmallMargin" />
                        
                        <Table 
                            backgroundDesign="Solid" 
                            sticky="ColumnHeaders" 
                            class="sapUiTinyMargin" 
                            items="{path: 'approval>/currentDetail/diff'}">
                            <columns>
                                <Column><Label text="Field" design="Bold" /></Column>
                                <Column><Label text="Old Data" design="Bold" /></Column>
                                <Column><Label text="New Data" design="Bold" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Label text="{approval>field}" design="Bold" />
                                        
                                        <ObjectStatus 
                                            text="{approval>oldData}"
                                            state="{= ${approval>/currentDetail/action} === 'DELETE' ? 'Warning' : 'None' }" />

                                        <ObjectStatus 
                                            text="{approval>newData}" 
                                            state="{= ${approval>/currentDetail/action} === 'DELETE' ? 'None' : (${approval>oldData} !== ${approval>newData} &amp;&amp; ${approval>oldData} !== 'N/A' &amp;&amp; ${approval>oldData} !== '-' ? 'Warning' : 'Success') }"
                                            icon="{= ${approval>/currentDetail/action} === 'DELETE' ? '' : (${approval>oldData} !== ${approval>newData} &amp;&amp; ${approval>oldData} !== 'N/A' &amp;&amp; ${approval>oldData} !== '-' ? 'sap-icon://edit' : 'sap-icon://sys-enter-2') }" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </content>

                <beginButton>
                    <Button text="Approve" type="Accept" icon="sap-icon://accept" press=".onApproveRequest" />
                </beginButton>
                <endButton>
                    <Button text="Reject" type="Reject" icon="sap-icon://decline" press=".onRejectRequest" />
                </endButton>

            </Dialog>

            <Dialog 
                id="rejectDialog"
                title="Confirm Rejection"
                type="Message"
                state="Error">
                <content>
                    <VBox class="sapUiTinyMarginTop">
                        <MessageStrip 
                            text="Rejecting this request will halt the current workflow"
                            type="Warning"
                            showIcon="true"
                            class="sapUiMediumMarginBottom" />
                        <Label text="Rejection Reason" required="true" />
                        <TextArea 
                            id="rejectReasonInput"
                            width="100%"
                            placeholder="Please enter the reason why this request is rejected..."
                            rows="4" />
                    </VBox>
                </content>
                <beginButton>
                    <Button text="Reject Request" type="Reject" press=".onConfirmReject" />
                </beginButton>
                <endButton>
                    <Button text="Cancel" press=".onCancelReject" />
                </endButton>
            </Dialog>

        </f:dependents>

    </f:DynamicPage>
</mvc:View>