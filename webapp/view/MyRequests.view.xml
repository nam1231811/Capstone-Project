<mvc:View
    controllerName="zapp.controller.MyRequests"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    displayBlock="true">
    
    <f:DynamicPage 
        id="myRequestsPageId" 
        headerExpanded="true" 
        class="sapUiResponsiveContentPadding">
        
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="My Requests" level="H2"/>
                </f:heading>          
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <VBox fitContainer="true" height="100%">
                
                <OverflowToolbar class="sapUiSmallMarginBottom sapUiShadow1" design="Solid" style="Clear">
                    <Title text="Status Filter:" level="H4" class="sapUiTinyMarginEnd" />
                    <SegmentedButton id="statusFilterBar" selectionChange=".onStatusFilterSelect" selectedKey="ALL">
                        <items>
                            <SegmentedButtonItem key="ALL" text="All" />
                            <SegmentedButtonItem key="PENDING" text="Pending" icon="sap-icon://pending" />
                            <SegmentedButtonItem key="REJECTED" text="Rejected" icon="sap-icon://decline" />
                            <SegmentedButtonItem key="APPROVED" text="Approved" icon="sap-icon://accept" />
                        </items>
                    </SegmentedButton>
                    
                    <ToolbarSpacer />
                    
                    <SearchField 
                        id="searchTable" 
                        placeholder="Search table..." 
                        width="250px" 
                        search=".onSearchTable" 
                        liveChange=".onSearchTable"
                        class="sapUiTinyMarginEnd" />
                        
                    <Button icon="sap-icon://refresh" text="Refresh" press=".onRefreshList" type="Emphasized"/>
                </OverflowToolbar>

                <List id="myRequestsTable" 
                      items="{myreq>/list}" 
                      noDataText="You have not created any requests yet."
                      showSeparators="None">
                    <items>
                        <CustomListItem type="Navigation" press=".onOpenDetailDialog" class="sapUiSmallMarginBottom sapUiShadow1">
                            <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMargin">
                                
                                <HBox alignItems="Center" width="45%">
                                    <core:Icon 
                                        src="{= ${myreq>action} === 'CREATE' ? 'sap-icon://add-document' : (${myreq>action} === 'UPDATE' ? 'sap-icon://edit' : 'sap-icon://delete') }"
                                        size="1.75rem"
                                        color="{= ${myreq>action} === 'CREATE' ? '#2b7c2b' : (${myreq>action} === 'UPDATE' ? '#e9730c' : '#bb0000') }"
                                        class="sapUiMediumMarginEnd" />
                                    
                                    <VBox>
                                        <Title text="Table: {myreq>tableName}" level="H4" wrapping="true"/>
                                        
                                        <Text text="No. {myreq>indexNo}" class="sapUiTinyMarginTop sapUiTinyMarginBottom sapUiMutedText"/>
                                        
                                        <HBox alignItems="Center">
                                            <Label text="Action:" design="Bold" class="sapUiTinyMarginEnd"/>
                                            <ObjectStatus 
                                                text="{myreq>action}" 
                                                state="{= ${myreq>action} === 'CREATE' ? 'Success' : (${myreq>action} === 'UPDATE' ? 'Warning' : 'Error') }"
                                                inverted="true" />
                                        </HBox>
                                    </VBox>
                                </HBox>

                                <VBox width="30%" class="sapUiHideOnPhone">
                                    <Label text="Last Updated:" design="Bold" />
                                    <Text text="{myreq>changedAt}" />
                                </VBox>

                                <VBox alignItems="End" width="25%">
                                    <ObjectStatus 
                                        text="{myreq>status}" 
                                        state="{= ${myreq>status} === 'APPROVED' ? 'Success' : (${myreq>status} === 'REJECTED' ? 'Error' : 'Warning') }" 
                                        icon="{= ${myreq>status} === 'APPROVED' ? 'sap-icon://accept' : (${myreq>status} === 'REJECTED' ? 'sap-icon://decline' : 'sap-icon://pending') }"
                                        inverted="true" 
                                        class="sapUiTinyMarginBottom" />
                                        
                                    <ObjectStatus 
                                        text="Action Required" 
                                        state="Error" 
                                        icon="sap-icon://message-warning"
                                        visible="{= ${myreq>status} === 'REJECTED' }" />
                                </VBox>
                                
                            </HBox>
                        </CustomListItem>
                    </items>
                </List>

            </VBox>
        </f:content>

        <f:dependents>
            <Dialog 
                id="resubmitDialog"
                title="{= ${myreq>/currentDetail/status} === 'REJECTED' ? 'Edit Rejected Request' : 'Request Details' }"
                contentWidth="800px" 
                contentHeight="500px" 
                resizable="true" 
                draggable="true"
                binding="{myreq>/currentDetail}">
                
                <content>
                    <VBox>
                        <ObjectHeader 
                            title="Target Table: {myreq>tableName}" 
                            icon="sap-icon://form" 
                            responsive="true" 
                            fullScreenOptimized="true">
                            <statuses>
                                <ObjectStatus 
                                    text="{myreq>action}"
                                    state="{= ${myreq>action} === 'CREATE' ? 'Success' : (${myreq>action} === 'DELETE' ? 'Error' : 'Warning') }"
                                    icon="{= ${myreq>action} === 'CREATE' ? 'sap-icon://add' : (${myreq>action} === 'DELETE' ? 'sap-icon://delete' : 'sap-icon://edit') }"
                                    inverted="true" />
                            </statuses>
                        </ObjectHeader>

                        <MessageStrip 
                            text="Comment for this Rejection: {myreq>rejectReason}" 
                            type="Error" 
                            showIcon="true" 
                            class="sapUiSmallMargin"
                            visible="{= ${myreq>status} === 'REJECTED' &amp;&amp; !${myreq>/isTableBusy} }" />

                        <Table 
                            alternateRowColors="true" 
                            busy="{myreq>/isTableBusy}" 
                            busyIndicatorDelay="0" 
                            backgroundDesign="Solid" 
                            sticky="ColumnHeaders"
                            class="sapUiTinyMargin" 
                            items="{myreq>fields}">
                            <columns>
                                <Column width="25%"><Label text="Field" design="Bold" /></Column>
                                <Column width="35%"><Label text="Old Data" design="Bold" /></Column>
                                <Column width="40%"><Label text="New Data" design="Bold" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Label text="{myreq>field}" design="Bold" />
                                        <Text text="{myreq>oldData}" />

                                        <HBox>
                                            <Input 
                                                value="{myreq>value}" 
                                                valueLiveUpdate="true"
                                                visible="{= ${myreq>/currentDetail/status} === 'REJECTED' &amp;&amp; ${myreq>/currentDetail/action} !== 'DELETE' }"
                                                editable="{= ${myreq>isKey} !== true }"
                                                valueState="{myreq>valueState}" 
                                                valueStateText="{myreq>valueStateText}"
                                                change=".onDialogInputChange" />
                                                
                                            <ObjectStatus 
                                                text="{myreq>value}"
                                                visible="{= ${myreq>/currentDetail/status} !== 'REJECTED' || ${myreq>/currentDetail/action} === 'DELETE' }"
                                                state="{= ${myreq>oldData} !== ${myreq>value} &amp;&amp; ${myreq>oldData} !== 'N/A' &amp;&amp; ${myreq>oldData} !== '-' ? 'Warning' : 'Success' }"
                                                icon="{= ${myreq>oldData} !== ${myreq>value} &amp;&amp; ${myreq>oldData} !== 'N/A' &amp;&amp; ${myreq>oldData} !== '-' ? 'sap-icon://edit' : 'sap-icon://sys-enter-2' }" />
                                        </HBox>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </content>

                <buttons>
                    <Button 
                        text="Resubmit Request" 
                        type="Accept" 
                        icon="sap-icon://paper-plane" 
                        press="._processResubmit"
                        visible="{= ${myreq>/currentDetail/status} === 'REJECTED' &amp;&amp; !${myreq>/isTableBusy} }" />
                        
                    <Button text="Close" type="Transparent" press=".onCloseDetailDialog" />
                </buttons>

            </Dialog>
        </f:dependents>

    </f:DynamicPage>
</mvc:View>