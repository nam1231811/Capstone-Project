<mvc:View
    controllerName="zapp.controller.DetailData"
    xmlns="sap.uxap"
    xmlns:m="sap.m"
    xmlns:f="sap.f"
    xmlns:form="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:suite="sap.suite.ui.commons.networkgraph"
    xmlns:layout="sap.suite.ui.commons.networkgraph.layout">
    
    <ObjectPageLayout
        id="ObjectPageLayout"
        showTitleInHeaderContent="true"
        alwaysShowContentHeader="false"
        preserveHeaderStateOnScroll="false"
        headerContentPinnable="true"
        isChildPage="true"
        upperCaseAnchorBar="false"
        showFooter="{viewModel>/isEditMode}">
        
        <headerTitle>
            <ObjectPageDynamicHeaderTitle>
                <actions>
                    <m:Button
                        text="Edit"
                        type="Emphasized"
                        visible="{= !${viewModel>/isEditMode} }"
                        press=".onEditAction"/>
                        
                    <m:Button
                        text="Delete"
                        type="Transparent"
                        visible="{= !${viewModel>/isEditMode} }"
                        press=".onDeleteRow"/>
                        
                    <m:Button
                        text="Close"
                        type="Transparent"
                        visible="{= !${viewModel>/isEditMode} }"
                        press=".onRollback"/>
                </actions>
            </ObjectPageDynamicHeaderTitle>
        </headerTitle>

         <headerContent>
            <m:FlexBox wrap="Wrap" alignItems="Center">

                <m:Avatar
                    src="sap-icon://employee"
                    displaySize="L"
                    displayShape="Square"
                    class="sapUiMediumMarginEnd"/>

                <l:VerticalLayout class="sapUiMediumMarginEnd">
                    <m:Label text="Category"/>
                    <m:ObjectStatus
                        text="Custom Table"
                        state="Information"/>
                </l:VerticalLayout>

                <l:VerticalLayout class="sapUiMediumMarginEnd">
                    <m:Label text="Table Name"/>
                    <m:ObjectStatus
                        text="{detailRecord>/title/table_name}"
                        state="Success"/>
                </l:VerticalLayout>

                <l:VerticalLayout class="sapUiMediumMarginEnd">
                    <m:Label text="Row"/>
                    <m:ObjectStatus
                        text="{detailRecord>/title/row_id}"
                        state="None"/>
                </l:VerticalLayout>

                <l:VerticalLayout>
                    <m:Label text="Primary Key"/>
                    <m:ObjectStatus
                        text="{detailRecord>/title/fieldname}"
                        state="None"/>
                </l:VerticalLayout>

            </m:FlexBox>
        </headerContent>
        <sections>
            <ObjectPageSection title="General Information">
                <subSections>
                    <ObjectPageSubSection>
                        <blocks>
                            <form:SimpleForm
                                maxContainerCols="2"
                                editable="true"
                                layout="ResponsiveGridLayout"
                                labelSpanL="12"
                                labelSpanM="12"
                                emptySpanL="0"
                                emptySpanM="0"
                                columnsL="1"
                                columnsM="1">
                                <form:content>
                                    <l:Grid 
                                        content="{detailRecord>/Data}" 
                                        defaultSpan="XL4 L4 M4 S12" 
                                        vSpacing="1" 
                                        class="sapUiSmallMargin">
                                        <l:content>
                                            <m:VBox class="sapUiSmallMarginBottom">
                                                <m:Label 
                                                    text="{detailRecord>fieldname}" 
                                                    design="Bold" 
                                                    class="sapUiTinyMarginBottom" 
                                                    required="{= ${detailRecord>keyFlag} === true }"/>

                                                <m:Input 
                                                    value="{detailRecord>value}" 
                                                    visible="{= ${viewModel>/isEditMode} &amp;&amp; !${detailRecord>keyFlag} }"
                                                    width="100%"
                                                    showValueHelp="{= ${detailRecord>has_value_help} === true || ${detailRecord>hasValueHelp} === true }" 
                                                    valueHelpRequest=".onDynamicValueHelp">
                                                    <m:customData>
                                                        <core:CustomData key="tableName" value="{detailRecord>table_name}" />
                                                        <core:CustomData key="fieldName" value="{detailRecord>fieldname}" />
                                                    </m:customData>
                                                </m:Input>
                                                <m:Text 
                                                    text="{detailRecord>value}" 
                                                    visible="{= ${viewModel>/isEditMode} !== true || ${detailRecord>keyFlag} === true }"
                                                    width="100%" />
                                            </m:VBox>
                                        </l:content>
                                    </l:Grid>
                                </form:content>
                            </form:SimpleForm>
                        </blocks>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>

            <ObjectPageSection title="Technical Information">
				<subSections>
					<ObjectPageSubSection>
						<blocks>
							<form:SimpleForm
								maxContainerCols="2"
								editable="false"
								layout="ResponsiveGridLayout"
								labelSpanL="12"
								labelSpanM="12"
								emptySpanL="0"
								emptySpanM="0"
								columnsL="1"
								columnsM="1">
								<form:content >
                                    <l:Grid 
                                        defaultSpan="XL6 L6 M6 S12" 
                                        vSpacing="1" 
                                        class="sapUiSmallMargin">
                                        <l:content>
                                            <m:VBox class="sapUiSmallMarginBottom">
                                                <m:Label 
                                                    text="Created By: " 
                                                    design="Bold" 
                                                    class="sapUiTinyMarginBottom" />

                                                <m:Text 
                                                    text="{detailRecord>/Data/0/createdBy}"
                                                    width="100%" />
                                            </m:VBox>

                                            <m:VBox class="sapUiSmallMarginBottom">
                                                <m:Label 
                                                    text="Created At: " 
                                                    design="Bold" 
                                                    class="sapUiTinyMarginBottom" />
                                                
                                                <m:Text 
                                                    text="{detailRecord>/Data/0/createdAt}"
                                                    width="100%" />
                                            </m:VBox>

                                            <m:VBox class="sapUiSmallMarginBottom">
                                                <m:Label 
                                                    text="Lasted Changed By: " 
                                                    design="Bold" 
                                                    class="sapUiTinyMarginBottom" />

                                                <m:Text 
                                                    text="{detailRecord>/Data/0/changedBy}"
                                                    width="100%" />
                                            </m:VBox>

                                            <m:VBox class="sapUiSmallMarginBottom">
                                                <m:Label 
                                                    text="Lasted Changed At: " 
                                                    design="Bold" 
                                                    class="sapUiTinyMarginBottom" />

                                                <m:Text 
                                                    text="{detailRecord>/Data/0/changedAt}"
                                                    width="100%" />
                                            </m:VBox>
											
                                        </l:content>
                                    </l:Grid>
                                </form:content>
							</form:SimpleForm>
						</blocks>
					</ObjectPageSubSection>
				</subSections>
			</ObjectPageSection>
            
            <ObjectPageSection title="Impact Analysis">
                <subSections>
                    <ObjectPageSubSection>
                        <blocks>
                            <suite:Graph 
                                id="impactGraph" width="100%" height="450px"
                                nodes="{graph>/nodes}" 
                                lines="{graph>/lines}">
                                    <suite:statuses>
                                        <suite:Status key="Success" title="Parent Table" />
                                        <suite:Status key="Information" title="Current Table" />
                                        <suite:Status key="Error" title="Affected Table" />
                                        <suite:Status key="Standard" title="Unaffected " />
                                        <suite:Status key="Warning" title="Affected" />
                                    </suite:statuses>
                                <suite:nodes>
                                    <suite:Node 
                                        key="{graph>key}" 
                                        title="{graph>title}" 
                                        icon="{graph>icon}" 
                                        status="{graph>status}"
                                        showDetailButton="false">
                                        <suite:actionButtons>
                                            <suite:ActionButton
                                                icon="sap-icon://table-view"
                                                title="{graph>title}" 
                                                press=".onShowChild"/>
                                        </suite:actionButtons>
                                    </suite:Node>
                                </suite:nodes>
                                
                                <suite:lines>
                                    <suite:Line from="{graph>from}" to="{graph>to}" status="{graph>status}"/>
                                </suite:lines>
                                
                            </suite:Graph>
                        </blocks>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>

        </sections>

        <footer>
            <m:OverflowToolbar>
                <m:ToolbarSpacer/>
                <m:Button
                    text="Save"
                    type="Emphasized"
                    press=".onSaveAction"
                    icon="sap-icon://save"/>
                <m:Button
                    text="Cancel"
                    type="Transparent"
                    press=".onCancelEdit"/>
            </m:OverflowToolbar>
        </footer>

    </ObjectPageLayout>
</mvc:View>