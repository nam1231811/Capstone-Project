<mvc:View
    controllerName="zapp.controller.DetailData"
    xmlns="sap.uxap"
    xmlns:m="sap.m"
    xmlns:f="sap.f"
    xmlns:form="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:suite="sap.suite.ui.commons.networkgraph"
    xmlns:layout="sap.suite.ui.commons.networkgraph.layout">
    
    <ObjectPageLayout
        id="ObjectPageLayout"
        showTitleInHeaderContent="true"
        alwaysShowContentHeader="false"
        preserveHeaderStateOnScroll="false"
        headerContentPinnable="true"
        isChildPage="true"
        upperCaseAnchorBar="false"
        showFooter="{viewModel>/isEditMode}">
        
        <headerTitle>
            <ObjectPageDynamicHeaderTitle>
                <actions>
                    <m:Button
                        text="Edit"
                        type="Emphasized"
                        visible="{= !${viewModel>/isEditMode} }"
                        press=".onEditAction"/>
                        
                    <m:Button
                        text="Delete"
                        type="Transparent"
                        visible="{= !${viewModel>/isEditMode} }"
                        press=".onDeleteRow"/>
                        
                    <m:Button
                        text="Close"
                        type="Transparent"
                        visible="{= !${viewModel>/isEditMode} }"
                        press=".onRollback"/>
                </actions>
            </ObjectPageDynamicHeaderTitle>
        </headerTitle>

         <headerContent>
            <m:FlexBox wrap="Wrap" alignItems="Center">

                <m:Avatar
                    src="sap-icon://employee"
                    displaySize="L"
                    displayShape="Square"
                    class="sapUiMediumMarginEnd"/>

                <l:VerticalLayout class="sapUiMediumMarginEnd">
                    <m:Label text="Category"/>
                    <m:ObjectStatus
                        text="User Table"
                        state="Information"/>
                </l:VerticalLayout>

                <l:VerticalLayout class="sapUiMediumMarginEnd">
                    <m:Label text="Employee ID"/>
                    <m:ObjectStatus
                        text="10001"
                        state="Success"/>
                </l:VerticalLayout>

                <l:VerticalLayout>
                    <m:Label text="City"/>
                    <m:ObjectStatus
                        text="Hanoi"
                        state="None"/>
                </l:VerticalLayout>

            </m:FlexBox>
        </headerContent>
        <sections>
            <ObjectPageSection title="General Information">
                <subSections>
                    <ObjectPageSubSection>
                        <blocks>
                            <form:SimpleForm
                                maxContainerCols="2"
                                editable="true"
                                layout="ResponsiveGridLayout"
                                labelSpanL="12"
                                labelSpanM="12"
                                emptySpanL="0"
                                emptySpanM="0"
                                columnsL="1"
                                columnsM="1">
                                <form:content>
                                    <l:Grid 
                                        content="{detailRecord>/Data}" 
                                        defaultSpan="XL4 L4 M4 S12" 
                                        vSpacing="1" 
                                        class="sapUiSmallMargin">
                                        <l:content>
                                            <m:VBox class="sapUiSmallMarginBottom">
                                                <m:Label 
                                                    text="{detailRecord>fieldname}" 
                                                    design="Bold" 
                                                    class="sapUiTinyMarginBottom" />

                                                <m:Input 
                                                    value="{detailRecord>value}" 
                                                    visible="{viewModel>/isEditMode}"
                                                    width="100%" />
                                                <m:Text 
                                                    text="{detailRecord>value}" 
                                                    visible="{= !${viewModel>/isEditMode} }"
                                                    width="100%" />
                                            </m:VBox>
                                        </l:content>
                                    </l:Grid>
                                </form:content>
                            </form:SimpleForm>
                        </blocks>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>

            <ObjectPageSection title="Impact Analysis">
                <subSections>
                    <ObjectPageSubSection>
                        <blocks>
                            <suite:Graph id="impactGraph" width="100%" height="450px"
                                         nodes="{graph>/nodes}" 
                                         lines="{graph>/lines}">
                                
                                <suite:nodes>
                                    <suite:Node 
                                        key="{graph>key}" 
                                        title="{graph>title}" 
                                        icon="{graph>icon}" 
                                        status="{graph>status}">
                                        <suite:attributes>
                                            <suite:ElementAttribute label="{graph>attrLabel}" value="{graph>attrValue}"/>
                                        </suite:attributes>
                                    </suite:Node>
                                </suite:nodes>
                                
                                <suite:lines>
                                    <suite:Line from="{graph>from}" to="{graph>to}" status="{graph>status}"/>
                                </suite:lines>
                                
                                <suite:layoutAlgorithm>
                                    <layout:LayeredLayout />
                                </suite:layoutAlgorithm>
                            </suite:Graph>
                        </blocks>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>

        </sections>

        <footer>
            <m:OverflowToolbar>
                <m:ToolbarSpacer/>
                <m:Button
                    text="Save"
                    type="Emphasized"
                    press=".onSaveAction"
                    icon="sap-icon://save"/>
                <m:Button
                    text="Cancel"
                    type="Transparent"
                    press=".onCancelEdit"/>
            </m:OverflowToolbar>
        </footer>

    </ObjectPageLayout>
</mvc:View>