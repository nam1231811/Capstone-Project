<mvc:View 
    controllerName="zapp.controller.Main" 
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns:uxap="sap.uxap" 
    xmlns="sap.m">
    <App id="afds">
        <uxap:ObjectPageLayout id="asdfsdf">
            <uxap:headerTitle>
                <uxap:ObjectPageHeader objectTitle="Table name: {view>/tableName}" />
            </uxap:headerTitle>
            <uxap:sections>
                <uxap:ObjectPageSection title="Technical Columns">
                    <uxap:subSections>
                        <uxap:ObjectPageSubSection>
                            <Table items="{displayModel>/Meta}">
                                <columns>
                                    <Column><Text text="Field Name"/></Column>
                                    <Column><Text text="Technical Name"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{displayModel>fieldname}"/>
                                            <Text text="{displayModel>datatype}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </uxap:ObjectPageSubSection>
                    </uxap:subSections>
                </uxap:ObjectPageSection>

                <uxap:ObjectPageSection title="Record Data">
                    <uxap:subSections>  
                        <uxap:ObjectPageSubSection>
                            <Table columns="{displayModel>/Meta}" id="dataTable" items="{displayModel>/Data}" >
                                <columns >
                                    <Column>
                                        <header>
                                            <Text text="{displayModel>fieldname}" />
                                        </header>
                                    </Column>
                                </columns>
                                <items>
                                    <ColumnListItem id="columnTemplate" />
                                </items>
                            </Table>
                        </uxap:ObjectPageSubSection>
                    </uxap:subSections>
                </uxap:ObjectPageSection>
            </uxap:sections>
        </uxap:ObjectPageLayout>
    </App>
</mvc:View>