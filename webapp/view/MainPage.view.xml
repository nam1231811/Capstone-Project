<mvc:View
    controllerName="zapp.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <f:DynamicPage id="dynamicPageId" headerExpanded="true" toggleHeaderOnTitleClick="true" class="sapUiNoContentPadding">
        
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{i18n>appTitle}" level="H2"/>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <fb:FilterBar id="filterBar" search=".onSearch" useToolbar="false" showGoOnFB="true" showClearOnFB="true" clear=".onClear">
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem groupName="BASIC" name="TableName" label="{i18n>tableName}" visibleInFilterBar="true">
                            <fb:control>
                                <Input id="searchInput" 
                                       placeholder="{i18n>searchPlaceholder}" 
                                       showValueHelp="true" 
                                       valueHelpRequest=".onValueHelpRequest" 
                                       submit=".onSearch" />
                            </fb:control>
                        </fb:FilterGroupItem>

                        <fb:FilterGroupItem groupName="BASIC" name="TableDescription" label="{i18n>tableDesc}" visibleInFilterBar="true">
                            <fb:control>
                                <Input id="searchDescInput" 
                                    placeholder="{i18n>searchDescPlaceholder}" 
                                    showSuggestion="true"
                                    suggestionItems="{/TableLookup}"
                                    suggestionItemSelected=".onSuggestionSelect"
                                    submit=".onSearch"
                                    showValueHelp="true" 
                                    valueHelpRequest=".onValueHelpRequest">
                                    <suggestionItems>
                                        <core:ListItem 
                                            key="{TableName}" 
                                            text="{Description}" 
                                            additionalText="{TableName}"/>
                                    </suggestionItems>
                                </Input>
                            </fb:control>
                        </fb:FilterGroupItem>
                    </fb:filterGroupItems>
                </fb:FilterBar>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <Table 
                id="dynamicTable" 
                items="{realData>/UniqueTables}"
                noDataText="{i18n>noDataText}"
                inset="false"
                sticky="ColumnHeaders,HeaderToolbar">
                
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{= ${i18n>listTableTitle} + ' (' + (${realData>/UniqueTables} ? ${realData>/UniqueTables}.length : 0) + ')' }" level="H2"/>
                        <ToolbarSpacer />

                        <Button icon="sap-icon://action-settings" type="Transparent" tooltip="{i18n>personalization}" press=".onPersonalization">
                            <layoutData><OverflowToolbarLayoutData priority="NeverOverflow" /></layoutData>
                        </Button>

                        <Button icon="sap-icon://globe" type="Transparent" tooltip="{i18n>language}" press=".onOpenSettings">
                            <layoutData><OverflowToolbarLayoutData priority="NeverOverflow" /></layoutData>
                        </Button>
                    </OverflowToolbar>
                </headerToolbar>
                
                <columns>
                    <Column id="colTableName"><Label text="{i18n>tableName}" design="Bold"/></Column>
                    <Column id="colTableDesc"><Label text="{i18n>tableDesc}" design="Bold"/></Column>
                    <Column id="colTotalCol"><Label text="{i18n>totalCol}" design="Bold"/></Column>
                    <Column id="colChangedBy"><Label text="{i18n>changedBy}" design="Bold"/></Column>
                    <Column id="colChangedAt"><Label text="{i18n>lastChangedAt}" design="Bold"/></Column>
                </columns>

                <items>
                    <ColumnListItem type="Navigation" press=".onRowPress" vAlign="Middle">
                        <cells>
                            <ObjectIdentifier title="{realData>table_name}" />
                            <Text text="{
                                path: 'realData>table_description',
                                type: 'sap.ui.model.type.String'
                            }" />
                            <ObjectStatus text="{realData>field_count} {i18n>columnsText}" state="Information" />
                            <Text text="{realData>user_name}" />
                            <Text text="{
                                path: 'realData>change_at', 
                                type: 'sap.ui.model.type.DateTime', 
                                formatOptions: { pattern: 'HH:mm:ss || dd/MM/yyyy' }
                            }" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </f:content>

    </f:DynamicPage>
</mvc:View>