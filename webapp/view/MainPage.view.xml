<mvc:View
    controllerName="zapp.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:core="sap.ui.core"
    xmlns:ui="sap.ui.table"
    displayBlock="true">

    <f:DynamicPage id="dynamicPageId" headerExpanded="true" toggleHeaderOnTitleClick="true" class="sapUiResponsiveContentPadding">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{i18n>appTitle}" level="H2"/>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>
        
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <fb:FilterBar id="filterBar" search=".onSearch" useToolbar="false" showGoOnFB="true" showClearOnFB="true" clear=".onClear">
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem groupName="BASIC" name="TableName" label="{i18n>tableName}" visibleInFilterBar="true">
                            <fb:control>
                                <Input id="searchInput" 
                                       placeholder="{i18n>searchPlaceholder}" 
                                       showValueHelp="true" 
                                       valueHelpRequest=".onValueHelpRequest" 
                                       submit=".onSearch" />
                            </fb:control>
                        </fb:FilterGroupItem>

                        <fb:FilterGroupItem groupName="BASIC" name="TableDescription" label="{i18n>tableDesc}" visibleInFilterBar="true">
                            <fb:control>
                                <Input id="searchDescInput" 
                                    placeholder="{i18n>searchDescPlaceholder}" 
                                    showSuggestion="true"
                                    suggestionItems="{/TableLookup}"
                                    suggestionItemSelected=".onSuggestionSelect"
                                    submit=".onSearch"
                                    showValueHelp="true" 
                                    valueHelpRequest=".onValueHelpRequest">
                                    <suggestionItems>
                                        <core:ListItem 
                                            key="{TableName}" 
                                            text="{Description}" 
                                            additionalText="{TableName}"/>
                                    </suggestionItems>
                                </Input>
                            </fb:control>
                        </fb:FilterGroupItem>
                    </fb:filterGroupItems>
                </fb:FilterBar>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <VBox fitContainer="true" class="roundedTableWrapper">
                <ScrollContainer
                    height="100%"
                    width="100%"
                    horizontal="true"
                    vertical="false">
                    
                    <OverflowToolbar width="100%" class="sapFDynamicPageAlignContent">
                        <Title text="{= ${i18n>listTableTitle} + ' (' + (${realData>/UniqueTables} ? ${realData>/UniqueTables}.length : 0) + ')' }" level="H2"/>
                        <ToolbarSpacer />

                        <Button icon="sap-icon://action-settings" type="Transparent" tooltip="{i18n>personalization}" press=".onPersonalization">
                            <layoutData><OverflowToolbarLayoutData priority="NeverOverflow" /></layoutData>
                        </Button>

                        <Button icon="sap-icon://globe" type="Transparent" tooltip="{i18n>language}" press=".onOpenSettings">
                            <layoutData><OverflowToolbarLayoutData priority="NeverOverflow" /></layoutData>
                        </Button>
                    </OverflowToolbar>

                    <ui:Table
                        id="dynamicTable"
                        width="100%"
                        rows="{realData>/UniqueTables}"
                        noData="{i18n>noDataText}"
                        class="myCustomCleanTable"
                        visibleRowCount="{= ${realData>/UniqueTables} ? (${realData>/UniqueTables}.length === 0 ? 1 : (${realData>/UniqueTables}.length > 15 ? 15 : ${realData>/UniqueTables}.length)) : 1 }"
                        rowSelectionChange=".onRowPress"
                        selectionBehavior="RowOnly"
                        selectionMode="Single">

                        <ui:columns>
                            <ui:Column id="colTableName" width="25%">
                                <Label text="{i18n>tableName}" design="Bold"/>
                                <ui:template>
                                    <ObjectIdentifier title="{realData>table_name}" />
                                </ui:template>
                            </ui:Column>

                            <ui:Column id="colTableDesc" width="30%">
                                <Label text="{i18n>tableDesc}" design="Bold"/>
                                <ui:template>
                                    <Text text="{
                                        path: 'realData>table_description',
                                        type: 'sap.ui.model.type.String'
                                    }" />
                                </ui:template>
                            </ui:Column>

                            <ui:Column id="colTotalCol" width="15%">
                                <Label text="{i18n>totalCol}" design="Bold"/>
                                <ui:template>
                                    <ObjectStatus text="{realData>field_count} {i18n>columnsText}" state="Information" />
                                </ui:template>
                            </ui:Column>

                            <ui:Column id="colChangedBy" width="15%">
                                <Label text="{i18n>changedBy}" design="Bold"/>
                                <ui:template>
                                    <Text text="{realData>user_name}" />
                                </ui:template>
                            </ui:Column>

                            <ui:Column id="colChangedAt" width="15%">
                                <Label text="{i18n>lastChangedAt}" design="Bold"/>
                                <ui:template>
                                    <Text text="{
                                        path: 'realData>change_at', 
                                        type: 'sap.ui.model.type.DateTime', 
                                        formatOptions: { pattern: 'HH:mm:ss || dd/MM/yyyy' }
                                    }" />
                                </ui:template>
                            </ui:Column>
                        </ui:columns>
                    </ui:Table>
                </ScrollContainer>
            </VBox>
        </f:content>

        <f:dependents>
            <SelectDialog
                id="langDialog"
                title="{i18n>language}"
                confirm=".onLangDialogConfirm">
                <items>
                    <StandardListItem title="English" description="EN" type="Active" />
                    <StandardListItem title="Tiếng Việt" description="VI" type="Active" />
                </items>
            </SelectDialog>

            <Dialog 
                id="persoDialog" 
                title="{i18n>personalization}" 
                contentWidth="300px">
                <content>
                    <List 
                        id="persoList" 
                        mode="MultiSelect" 
                        includeItemInSelection="true" />
                </content>
                <beginButton>
                    <Button text="OK" type="Emphasized" press=".onPersoDialogConfirm" />
                </beginButton>
                <endButton>
                    <Button text="Cancel" press=".onPersoDialogCancel" />
                </endButton>
            </Dialog>
        </f:dependents>

    </f:DynamicPage>
</mvc:View>