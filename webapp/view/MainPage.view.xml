<mvc:View 
    controllerName="zapp.controller.Main" 
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns:uxap="sap.uxap" 
    xmlns="sap.m"
    xmlns:u="sap.ui.unified"> <App id="afds">
        <uxap:ObjectPageLayout id="asdfsdf">
            <uxap:headerTitle>
                <uxap:ObjectPageHeader objectTitle="Table name: {overall>/tableName}" />
            </uxap:headerTitle>
            
            <uxap:sections>
                <uxap:ObjectPageSection title="Technical Columns">
                    <uxap:subSections>
                        <uxap:ObjectPageSubSection>
                            <Table items="{displayModel>/Meta}">
                                <columns>
                                    <Column>
                                        <Text text="Field Name"/>
                                    </Column>
                                    <Column hAlign="End">
                                        <Text text="Technical Name"/>
                                    </Column>
                                </columns>
                                <items>
                                    <ColumnListItem type="Navigation">
                                        <cells>
                                            <Text text="{displayModel>fieldname}"/>
                                            <Text text="{displayModel>datatype}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </uxap:ObjectPageSubSection>
                    </uxap:subSections>
                </uxap:ObjectPageSection>

                <uxap:ObjectPageSection title="Record Data ({overall>/count})">
                    <uxap:subSections>  
                        <uxap:ObjectPageSubSection >
                            <VBox>
                                <OverflowToolbar class="sapFDynamicPageAlignContent">
                                    <ToolbarSpacer/>
                                    
                                    <u:FileUploader 
    id="excelUploader" 
    fileType="xlsx" 
    buttonOnly="true" 
    icon="sap-icon://excel-attachment" 
    buttonText="Upload Excel" 
    style="Emphasized"
    sameFilenameAllowed="true"
    change=".onUploadExcelPress"/>
                                    <SearchField search=".onSearch" width="17.5rem"/>
                                    <OverflowToolbarButton icon="sap-icon://add" text="Add" type="Transparent" press=".onAdd"/>
                                    <OverflowToolbarButton icon="sap-icon://sort" text="Sort" type="Transparent" press=".onSort"/>
                                    <OverflowToolbarButton icon="sap-icon://filter" text="Filter" type="Transparent" press=".onFilter"/>
                                </OverflowToolbar>
                                
                                <Table 
                                    columns="{displayModel>/Meta}" 
                                    id="dataTable" 
                                    items="{displayModel>/Data}" 
                                    growing="true"
                                    growingThreshold="20">
                                    <columns >
                                        <Column>
                                            <header>
                                                <Text text="{displayModel>fieldname}" />
                                            </header>
                                        </Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem id="columnTemplate" type="Navigation" press=".onListItemPress"/>
                                    </items>
                                </Table>
                            </VBox>
                        </uxap:ObjectPageSubSection>
                    </uxap:subSections>
                </uxap:ObjectPageSection>
            </uxap:sections>
        </uxap:ObjectPageLayout>
    </App>
</mvc:View>