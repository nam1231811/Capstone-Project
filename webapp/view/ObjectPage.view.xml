<mvc:View 
    controllerName="zapp.controller.ObjectPage" 
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns:uxap="sap.uxap" 
    xmlns:core="sap.ui.core"
    xmlns:ui="sap.ui.table"
    xmlns:u="sap.ui.unified"
    xmlns="sap.m">
    <App id="TablePage">
        <uxap:ObjectPageLayout id="TableContent">
        <uxap:headerTitle>
                <uxap:ObjectPageDynamicHeaderTitle>
                    
                    <uxap:expandedHeading>
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <core:Icon src="sap-icon://table-chart" size="3rem" class="sapUiMediumMarginEnd" color="#0a6ed1" />
                            <Title text="{overall>/tableName}" level="H1" titleStyle="H1" />
                        </HBox>
                    </uxap:expandedHeading>
                    
                    <uxap:snappedHeading>
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://table-chart" size="1.5rem" class="sapUiSmallMarginEnd" color="#0a6ed1" />
                            <Title text="{overall>/tableName}" level="H2" titleStyle="H2" />
                        </HBox>
                    </uxap:snappedHeading>
                    
                </uxap:ObjectPageDynamicHeaderTitle>
            </uxap:headerTitle>
            
            <uxap:headerContent>
                <HBox wrap="Wrap" alignItems="Center" class="sapUiLargeMarginBegin sapUiSmallMarginBottom">
                    
                    <HBox alignItems="Center">
                        <core:Icon src="sap-icon://hint" color="#e9730c" size="1.2rem" class="sapUiTinyMarginEnd" />
                        <Title text="{overall>/tableDesc}" level="H5" titleStyle="H5" class="sapThemeCriticalText" />
                    </HBox>

                    <Title text="|" level="H4" class="sapUiMutedText sapUiMediumMarginBeginEnd" />

                    <HBox alignItems="Center">
                        <Title text="Total Records:" level="H5" titleStyle="H5" class="sapUiSmallMarginEnd" />
                        <core:Icon src="sap-icon://table-row" color="#107e3e" size="1.2rem" class="sapUiTinyMarginEnd"/>
                        <ObjectNumber number="{overall>/count}" unit="Rows" state="Success" />
                    </HBox>
                        
                    <Title text="|" level="H4" class="sapUiMutedText sapUiMediumMarginBeginEnd" />

                    <HBox alignItems="Center">
                        <Title text="Total Columns:" level="H5" titleStyle="H5" class="sapUiSmallMarginEnd" />
                        <core:Icon src="sap-icon://add-column" color="#0a6ed1" size="1.2rem" class="sapUiTinyMarginEnd"/>
                        <ObjectNumber number="{overall>/colCount}" unit="Columns" state="Information" />
                    </HBox>

                </HBox>
            </uxap:headerContent>

            <uxap:sections>
                <uxap:ObjectPageSection title="Technical Columns">
                    <uxap:subSections>
                        <uxap:ObjectPageSubSection>
                            <Table items="{displayModel>/UiMeta}" id="metadata">
                                <columns>
                                    <Column><Text text="Position"/></Column>
                                    <Column><Text text="Field Name"/></Column>
                                    <Column><Text text="Display Label"/></Column>
                                    <Column><Text text="Data Type"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem type="Navigation" press=".onMedataPress">
                                        <cells>
                                            <Text text="{displayModel>field_pos}"/>
                                            <Text text="{displayModel>fieldname}"/>
                                            <Text text="{displayModel>scrtextM}"/>
                                            <Text text="{displayModel>datatype}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </uxap:ObjectPageSubSection>
                    </uxap:subSections>
                </uxap:ObjectPageSection>

                <uxap:ObjectPageSection title="Record Data ({overall>/count})">
                    <uxap:subSections>
                        <uxap:ObjectPageSubSection>
                            <VBox>
                              <ScrollContainer
                                height="100%"
                                width="100%"
                                horizontal="true"
                                vertical="false">
                                <OverflowToolbar width="92vw" class="sapFDynamicPageAlignContent">
                                    <SearchField search=".onSearch" width="17.5rem"/>
                                    <ToolbarSpacer/>

                                    <u:FileUploader
                                        id="excelUploader"
                                        fileType="xlsx"
                                        buttonOnly="true"
                                        icon="sap-icon://excel-attachment"
                                        buttonText="Upload"
                                        style="Emphasized"
                                        sameFilenameAllowed="true"
                                        change=".onUploadExcelPress"/>

                                    <Button 
                                        id="btnDownload" 
                                        icon="sap-icon://download" 
                                        type="Accept" 
                                        text="Download" 
                                        press=".onDownloadExcelPress" 
                                        tooltip="Xuất dữ liệu ra file Excel"/>

                                    <OverflowToolbarButton icon="sap-icon://add" text="Add" type="Transparent" press=".onAdd"/>
                                    <OverflowToolbarButton icon="sap-icon://filter" text="Filter" type="Transparent" press=".onFilter"/> 
                                    <OverflowToolbarButton icon="sap-icon://action-settings" text="Personalization" type="Transparent" press=".onPersonalization"/>
                                </OverflowToolbar>

                                <ui:Table
                                    id="dataTable"
                                    width="92vw"
                                    rows="{displayModel>/Data}" 
                                    visibleRowCount="{displayModel>/visibleRowCount}"
                                    columns="{path: 'displayModel>/Meta', factory: '.createDynamicColumn'}"
                                    class="myCustomCleanTable"
                                    rowSelectionChange=".onListItemPress"
                                    selectionBehavior="RowOnly"
                                    selectionMode="MultiToggle"
                                    >

                                </ui:Table>
                                </ScrollContainer>
                            </VBox>
                        </uxap:ObjectPageSubSection>
                    </uxap:subSections>
                </uxap:ObjectPageSection>
            </uxap:sections>
             
            <uxap:footer>
		    	<OverflowToolbar>
		    		<ToolbarSpacer/>
		    		<Button type="Accept" text="Save" press=".onSave" width="5rem"/>
		    		<Button type="Reject" text="Cancel" press="._onEditToggleButtonPress" width="5rem"/>
		    	</OverflowToolbar>
		    </uxap:footer>
        </uxap:ObjectPageLayout>
    </App>
</mvc:View>