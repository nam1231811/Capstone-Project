<mvc:View
    controllerName="zapp.controller.AuditLog"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:suite="sap.suite.ui.commons"
    displayBlock="true">

    <f:DynamicPage id="auditDynamicPage" headerExpanded="true" toggleHeaderOnTitleClick="true" class="sapUiResponsiveContentPadding">
        
        <f:dependents>
            <Dialog id="auditTrailDialog"
                    title="Audit Trail - Record ID: {audit>/selectedRowId}"
                    contentWidth="1200px"
                    contentHeight="1000px"
                    resizable="true"
                    draggable="true">
                <content>
                    <ScrollContainer width="100%" height="100%" vertical="true" horizontal="true">
                        <suite:ProcessFlow
                            id="auditProcessFlow"
                            scrollable="true"
                            foldedCorners="true"
                            nodePress=".onNodePress"
                            nodes="{audit>/processNodes}"
                            lanes="{audit>/processLanes}">
                            <suite:nodes>
                                <suite:ProcessFlowNode
                                    laneId="{audit>lane}"
                                    nodeId="{audit>id}"
                                    title="{audit>title}"
                                    titleAbbreviation="{audit>titleAbbreviation}"
                                    children="{audit>children}"
                                    state="{audit>state}"
                                    stateText="{audit>status}"
                                    texts="{audit>texts}"
                                    />
                            </suite:nodes>
                            <suite:lanes>
                                <suite:ProcessFlowLaneHeader
                                    laneId="{audit>id}"
                                    iconSrc="{audit>icon}"
                                    text="{audit>label}"
                                    position="{audit>position}" />
                            </suite:lanes>
                        </suite:ProcessFlow>
                    </ScrollContainer>
                </content>
                <buttons>
                    <Button text="Close" press=".onCloseTrailDialog" type="Transparent"/>
                </buttons>
            </Dialog>

            <Dialog id="detailNodeDialog"
                    title="Details: {audit>/selectedNodeAction}"
                    contentWidth="700px"
                    contentHeight="500px"
                    resizable="true"
                    draggable="true">
                <customHeader>
                    <OverflowToolbar>
                        <Title text="Timestamp: {audit>/selectedNodeTime}" class="sapUiTinyMarginBegin"/>
                        <ToolbarSpacer />
                        <Button text="Revert"
                                icon="sap-icon://undo"
                                type="Emphasized"
                                visible="{= ${audit>/selectedNodeAction} === 'UPDATE' || ${audit>/selectedNodeAction} === 'DELETE'}"
                                press=".onRequestRevert" />
                    </OverflowToolbar>
                </customHeader>
                <content>
                    <Table items="{audit>/selectedNodeChanges}"
                           noDataText="No changes recorded for this action"
                           backgroundDesign="Transparent"
                           showSeparators="Inner">
                        <columns>
                            <Column width="30%"><Label text="Field Changed" design="Bold" /></Column>
                            <Column width="35%"><Label text="Old Value" /></Column>
                            <Column width="35%" ><Label text="New Value" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                            <Text text="{audit>field}" />
                            <Text text="{audit>oldValue}" />
                                <ObjectStatus 
                                    text="{audit>newValue}" 
                                    state="{= ${audit>/selectedNodeAction} === 'CREATE' ? 'Success' : (${audit>/selectedNodeAction} === 'DELETE' ? 'Error' : (${audit>isChanged} ? 'Warning' : 'Success')) }" 
                                    icon="{= ${audit>/selectedNodeAction} === 'CREATE' ? 'sap-icon://sys-enter-2' : (${audit>/selectedNodeAction} === 'DELETE' ? 'sap-icon://delete' : (${audit>isChanged} ? 'sap-icon://edit' : 'sap-icon://sys-enter-2')) }" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </content>
                <buttons>
                    <Button text="Close Details" press=".onCloseDetailDialog" type="Transparent"/>
                </buttons>
            </Dialog>
        </f:dependents>

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <HBox alignItems="Center">
                        <Title text="Audit Log" level="H2"/>
                    </HBox>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>
        
        <f:content>
            <layout:Grid defaultSpan="XL12 L12 M12 S12" class="sapUiSmallMarginTop">
                
                <f:Card>
                    <f:header>
                        <card:Header title="Table Search" subtitle="Select a table to view its audit log" iconSrc="sap-icon://sys-find" />
                    </f:header>
                    <f:content>
                        <HBox alignItems="Center" wrap="Wrap" class="sapUiSmallMargin">
                            <Label text="Data Table:" design="Bold" class="sapUiTinyMarginEnd sapUiTinyMarginTopBottom" />
                            <Input id="auditSearchInput"
                                   placeholder="Enter table name..."
                                   showValueHelp="true"
                                   valueHelpRequest=".onValueHelpRequest"
                                   submit=".onSearchAuditLog"
                                   width="400px"
                                   class="sapUiTinyMarginEnd" />
                            <Button text="Search" type="Emphasized" icon="sap-icon://search" press=".onSearchAuditLog" class="sapUiTinyMarginEnd"/>
                            <Button text="Clear" type="Transparent" icon="sap-icon://clear-filter" press=".onClearAuditSearch" tooltip="Clear search criteria"/>
                        </HBox>
                    </f:content>
                </f:Card>

                <f:Card>
                    <f:header>
                        <card:Header title="Recent Changes" subtitle="Click the details button to view the data lifecycle (Audit Trail)" iconSrc="sap-icon://table-view"/>
                    </f:header>
                    <f:content>
                        <Table id="auditMasterTable"
                               items="{audit>/mainLogs}"
                               noDataText="No data available. Please select a table to view its audit log"
                               alternateRowColors="true"
                               growing="true"
                               growingThreshold="20"
                               class="sapUiTinyMarginBottom">
                            <columns>
                                <Column width="20%"><Label text="Data Key" design="Bold"/></Column>

                                <Column width="20%">
                                    <header>
                                        <HBox alignItems="Center" width="100%">
                                            <Label text="Latest Action" design="Bold"/>
                                            <Button icon="sap-icon://filter" type="Transparent" press=".onOpenActionFilter"/>
                                        </HBox>
                                    </header>

                                    <dependents>
                                        <ResponsivePopover id="actionFilterPopover" title="Filter by Action" placement="Bottom" contentWidth="200px">
                                            <content>
                                                <List id="actionFilterList" 
                                                      mode="MultiSelect" 
                                                      items="{audit>/uniqueActions}">
                                                    <StandardListItem title="{audit>actionName}" />
                                                </List>
                                            </content>
                                            <beginButton>
                                                <Button text="OK" press=".onApplyActionFilter" type="Emphasized"/>
                                            </beginButton>
                                            <endButton>
                                                <Button text="Cancel" press=".onClearActionFilter" type="Transparent"/>
                                            </endButton>
                                        </ResponsivePopover>
                                    </dependents>
                                </Column>

                                <Column width="20%">
                                    <header>
                                        <HBox alignItems="Center" width="100%">
                                            <Label text="Performed by" design="Bold"/>
                                            <Button icon="sap-icon://filter" type="Transparent" press=".onOpenUserFilter"/>
                                        </HBox>
                                    </header>

                                    <dependents>
                                        <ResponsivePopover id="userFilterPopover" title="Filter by User" placement="Bottom" contentWidth="200px">
                                            <content>
                                                <List id="userFilterList" 
                                                      mode="MultiSelect" 
                                                      items="{audit>/uniqueUsers}">
                                                    <StandardListItem title="{audit>userName}" />
                                                </List>
                                            </content>
                                            <beginButton>
                                                <Button text="OK" press=".onApplyUserFilter" type="Emphasized"/>
                                            </beginButton>
                                            <endButton>
                                                <Button text="Cancel" press=".onClearUserFilter" type="Transparent"/>
                                            </endButton>
                                        </ResponsivePopover>
                                    </dependents>
                                </Column>
                                
                                <Column width="25%" >
                                    <header>
                                        <HBox alignItems="Center" width="100%">
                                            <Label text="Timestamp" design="Bold"/>
                                            <Button icon="sap-icon://filter" type="Transparent" press=".onOpenDateFilter"/>
                                        </HBox>
                                    </header>

                                    <dependents>
                                        <ResponsivePopover id="dateFilterPopover" title="Filter by Date Range" placement="Bottom">
                                            <content>
                                                <VBox class="sapUiSmallMargin">
                                                    <DateRangeSelection 
                                                        id="dateRangeFilter" 
                                                        change=".onApplyDateFilter" 
                                                        displayFormat="dd/MM/yyyy"
                                                        placeholder="Start date - End date"/>

                                                    <HBox justifyContent="End" class="sapUiTinyMarginTop">
                                                        <Button text="Clear" press=".onClearDateFilter" type="Reject"/>
                                                    </HBox>
                                                </VBox>
                                            </content>
                                        </ResponsivePopover>
                                    </dependents>
                                </Column>
                                
                                <Column width="15%">
                                    <Button text="Clear all filters" type="Transparent" icon="sap-icon://clear-filter" press=".onClearAllFilters"/>
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem vAlign="Middle">
                                    <cells>
                                        <VBox height="50px" justifyContent="Center">
                                            <ObjectIdentifier 
                                                title="{audit>displayKey}" />
                                        </VBox>
                            
                                        <VBox height="50px" justifyContent="Center">
                                            <ObjectStatus text="{audit>lastAction}"
                                                state="{= ${audit>lastAction} === 'CREATE' ? 'Success' : (${audit>lastAction} === 'DELETE' ? 'Error' : 'Warning') }"
                                                icon="{= ${audit>lastAction} === 'CREATE' ? 'sap-icon://add' : (${audit>lastAction} === 'DELETE' ? 'sap-icon://delete' : 'sap-icon://edit') }"/>
                                        </VBox>
                            
                                        <VBox height="50px" justifyContent="Center">
                                            <Text text="{audit>lastUser}" wrapping="true" />
                                        </VBox>
                            
                                        <VBox height="50px" justifyContent="Center">
                                            <Text text="{audit>lastTimestamp}" wrapping="true" />
                                        </VBox>
                            
                                        <VBox height="50px" justifyContent="Center">
                                            <Button text="Details" icon="sap-icon://history" press=".onViewAuditTrail" type="Transparent"/>
                                        </VBox>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </f:content>
                </f:Card>
            </layout:Grid>
        </f:content>
    </f:DynamicPage>
</mvc:View>